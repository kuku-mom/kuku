---
import MarketingPageLayout from '@/layouts/marketing_page_layout.astro';

type MilestonePhase = 'shipped' | 'progress' | 'planned';

interface Milestone {
  phase: MilestonePhase;
  phaseLabel: string;
  title: string;
  subtitle: string;
  body: string;
  viz: 'foundation' | 'launch' | 'rebuild' | 'release' | 'search' | 'sync' | 'extensions';
  vizCaption: string;
}

const milestones: Milestone[] = [
  {
    phase: 'shipped',
    phaseLabel: 'Shipped',
    title: 'Zero to First',
    subtitle: 'Building the foundation',
    body: 'Chose Tauri v2 over Electron for native performance. Built with React 19 and Tiptap. Shipped with core Markdown editing, bidirectional [[wikilinks]], backlink panel, and force-directed graph view — all running locally.',
    viz: 'foundation',
    vizCaption: 'Native stack',
  },
  {
    phase: 'shipped',
    phaseLabel: 'Shipped',
    title: 'Product Hunt Launch',
    subtitle: 'AI features & community feedback',
    body: 'Launched on Product Hunt with AI Agent (Gemini), local speech-to-text (Whisper.cpp), inline diff previews, and full-text search. The community response made it clear: users want complete control over their data and infrastructure.',
    viz: 'launch',
    vizCaption: 'Shipped capabilities',
  },
  {
    phase: 'shipped',
    phaseLabel: 'Shipped',
    title: 'The Rebuild',
    subtitle: 'SolidJS + pure ProseMirror',
    body: 'Complete rewrite from the ground up. Migrated to SolidJS and pure ProseMirror for better performance, no proprietary wrappers, and a clean foundation for the plugin system. This is the right foundation for everything we are building next.',
    viz: 'rebuild',
    vizCaption: 'Editor core',
  },
  {
    phase: 'progress',
    phaseLabel: 'In progress',
    title: '1.0 Release',
    subtitle: 'Open source everything',
    body: 'Fully open source under the MIT license — client, server, and infra code all in one repo. Meeting notes with local Whisper, GitHub Sync, Homebrew distribution, and full server code with self-hosting guides. Three ways to use: self-host, bring your own services, or use kuku.mom.',
    viz: 'release',
    vizCaption: 'Licensing',
  },
  {
    phase: 'planned',
    phaseLabel: 'Post-1.0 · Planned',
    title: 'Enhanced Search & Graph',
    subtitle: 'Semantic + hybrid retrieval',
    body: 'Semantic understanding powered by local embedding models. Run nomic-embed-text on-device using Ollama or ONNX Runtime. Hybrid search combining keywords with semantic similarity. Smart graph view based on semantic connections.',
    viz: 'search',
    vizCaption: 'Hybrid search',
  },
  {
    phase: 'planned',
    phaseLabel: 'Post-1.0 · Planned',
    title: 'Sync & Mobile',
    subtitle: 'Encrypted sync & native apps',
    body: 'Zero-knowledge encrypted sync through kuku.mom, self-hosted servers, or your own S3 bucket. Native iOS and Android apps with full editing capabilities. Smart conflict resolution and offline-first design.',
    viz: 'sync',
    vizCaption: 'Sync model',
  },
  {
    phase: 'planned',
    phaseLabel: 'Post-1.0 · Planned',
    title: 'Extension Ecosystem',
    subtitle: 'Plugins & collaboration',
    body: 'Public plugin SDK with full documentation. Community plugin marketplace. Real-time collaboration extensions become possible. Web clipper for capturing content. AI Memory Sharing — let other AI assistants access your knowledge base through a secure, local API.',
    viz: 'extensions',
    vizCaption: 'Plugins',
  },
];
---

<MarketingPageLayout
  wide
  title="Roadmap | kuku"
  description="How kuku evolved from a native Markdown vault to open source, AI-aware editing — and what is next."
>
  <div class="lp-roadmap">
    <h1 data-i18n="rm.title">Roadmap</h1>
    <p class="lp-lead" data-i18n="rm.lead">
      Milestones and what is next — quiet visuals, same One Light sensibility as the product.
    </p>
    <p class="lp-rm-translated" data-i18n="rm.translated"></p>

    <section class="lp-rm-authors" id="lp-rm-authors" aria-label="Original authors">
      <div class="lp-rm-authors-intro">
        <p class="lp-rm-authors-kicker" data-i18n="rm.authors.kicker">Original authors</p>
        <p class="lp-rm-authors-lead" data-i18n="rm.authors.lead">
          The people behind the narrative on this page.
        </p>
      </div>
      <div class="lp-rm-authors-grid">
        <article
          class="lp-rm-author-card"
          data-lp-rm-author
          tabindex="0"
          role="button"
          aria-expanded="false"
        >
          <div class="lp-rm-author-main">
            <div class="lp-rm-author-avatar" aria-hidden="true">
              <img
                src="/authors/gbrain-portrait.webp"
                alt=""
                width="128"
                height="128"
                loading="lazy"
                decoding="async"
                class="lp-rm-author-photo"
              />
            </div>
            <div class="lp-rm-author-text">
              <h3 class="lp-rm-author-name" data-i18n="rm.author1.name">Gyeongtaek Kim</h3>
              <p class="lp-rm-author-role" data-i18n="rm.author1.role">Founder — kuku</p>
            </div>
          </div>
          <p class="lp-rm-author-more" data-i18n="rm.author1.more">
            Built kuku as a native Markdown workspace with AI that edits real files on disk.
          </p>
          <p class="lp-rm-author-cta" data-i18n="rm.authors.tap_hint">Click card for more</p>
        </article>
        <article
          class="lp-rm-author-card"
          data-lp-rm-author
          tabindex="0"
          role="button"
          aria-expanded="false"
        >
          <div class="lp-rm-author-main">
            <div class="lp-rm-author-avatar" aria-hidden="true">
              <img
                src="/authors/llmwiki-portrait.jpg"
                alt=""
                width="128"
                height="128"
                loading="lazy"
                decoding="async"
                class="lp-rm-author-photo"
              />
            </div>
            <div class="lp-rm-author-text">
              <h3 class="lp-rm-author-name" data-i18n="rm.author2.name">Contributing coverage</h3>
              <p class="lp-rm-author-role" data-i18n="rm.author2.role">Press · interview</p>
            </div>
          </div>
          <p class="lp-rm-author-more" data-i18n="rm.author2.more">
            Editorial context that grounds the roadmap story in real-world practice.
          </p>
          <p class="lp-rm-author-cta" data-i18n="rm.authors.tap_hint">Click card for more</p>
        </article>
      </div>
    </section>

    <div class="lp-rm-list" id="lp-rm-list" aria-label="Product roadmap">
      {
        milestones.map((m, i) => (
          <div class="lp-rm-item" style={`--rm-i: ${i}`}>
            <article class="lp-rm-card" data-rm-viz={m.viz}>
              <div class="lp-rm-copy">
                <div class="lp-rm-meta">
                  <span
                    class:list={['lp-rm-pill', `lp-rm-pill--${m.phase}`]}
                    data-i18n={`rm.${m.viz}.phase`}
                  >
                    {m.phaseLabel}
                  </span>
                  <span class="lp-rm-era" data-i18n={`rm.${m.viz}.sub`}>
                    {m.subtitle}
                  </span>
                </div>
                <h2 class="lp-rm-title" data-i18n={`rm.${m.viz}.title`}>
                  {m.title}
                </h2>
                <p class="lp-rm-body" data-i18n={`rm.${m.viz}.body`}>
                  {m.body}
                </p>
              </div>
              <div class:list={['lp-rm-viz', `lp-rm-viz--${m.viz}`]} aria-hidden="true">
                <div class="lp-rm-viz-inner">
                  {m.viz === 'foundation' && (
                    <>
                      <div class="lp-rm-stack">
                        <span class="lp-rm-chip">Tauri v2</span>
                        <span class="lp-rm-chip lp-rm-chip--quiet">React 19</span>
                        <span class="lp-rm-chip lp-rm-chip--quiet">Tiptap</span>
                      </div>
                      <p class="lp-rm-mono lp-rm-wl">[[wikilinks]]</p>
                      <div class="lp-rm-graph-min">
                        <span class="lp-rm-graph-min__dot" />
                        <span class="lp-rm-graph-min__dot" />
                        <span class="lp-rm-graph-min__hub" />
                        <span class="lp-rm-graph-min__dot" />
                      </div>
                    </>
                  )}
                  {m.viz === 'launch' && (
                    <ul class="lp-rm-min-list">
                      <li class="lp-rm-min-list__li lp-rm-min-list__li--accent">
                        AI Agent · Gemini
                      </li>
                      <li class="lp-rm-min-list__li">Whisper.cpp</li>
                      <li class="lp-rm-min-list__li lp-rm-min-list__li--muted">
                        Inline diff · search
                      </li>
                    </ul>
                  )}
                  {m.viz === 'rebuild' && (
                    <>
                      <div class="lp-rm-bars">
                        <span class="lp-rm-bar" />
                        <span class="lp-rm-bar lp-rm-bar--mid" />
                        <span class="lp-rm-bar lp-rm-bar--short" />
                      </div>
                      <div class="lp-rm-tags">
                        <span>SolidJS</span>
                        <span>ProseMirror</span>
                      </div>
                    </>
                  )}
                  {m.viz === 'release' && (
                    <div class="lp-rm-lic">
                      <div class="lp-rm-lic__row">
                        <span class="lp-rm-lic__badge">MIT</span>
                      </div>
                      <p class="lp-rm-mono lp-rm-lic__hint">Client · Server · Infra</p>
                    </div>
                  )}
                  {m.viz === 'search' && (
                    <>
                      <div class="lp-rm-find">
                        <span class="lp-rm-mono lp-rm-find__kbd">Cmd+K</span>
                        <span class="lp-rm-find__ph">Hybrid query…</span>
                      </div>
                      <p class="lp-rm-mono lp-rm-find__sub">nomic-embed · on-device</p>
                    </>
                  )}
                  {m.viz === 'sync' && (
                    <div class="lp-rm-sync-viz" aria-hidden="true">
                      <svg
                        class="lp-rm-sync-ic"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <rect x="5" y="2" width="14" height="20" rx="3" ry="3" />
                        <path d="M12 18h.01" />
                      </svg>
                      <span class="lp-rm-sync-path">
                        <span class="lp-rm-sync-dash" />
                      </span>
                      <svg
                        class="lp-rm-sync-ic lp-rm-sync-ic--cloud"
                        width="30"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
                      </svg>
                    </div>
                  )}
                  {m.viz === 'extensions' && (
                    <div class="lp-rm-ext-icons" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path
                          d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"
                          stroke-linecap="round"
                        />
                        <circle cx="12" cy="12" r="3" />
                      </svg>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
                      </svg>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                      </svg>
                      <svg
                        class="lp-rm-ext-icons__on"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <rect x="4" y="4" width="16" height="16" rx="2" />
                        <path d="m9 9 6 6M15 9l-6 6" />
                      </svg>
                    </div>
                  )}
                  <p class="lp-rm-viz-cap" data-i18n={`rm.${m.viz}.cap`}>
                    {m.vizCaption}
                  </p>
                </div>
              </div>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</MarketingPageLayout>

<style>
  .lp-roadmap {
    padding-bottom: 1rem;
  }

  .lp-rm-translated {
    margin: -1rem 0 2rem;
    font-size: 0.875rem;
    font-style: italic;
    color: var(--ol-text3);
  }

  .lp-rm-translated:empty {
    display: none;
  }

  .lp-rm-list {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
    margin-top: 0.35rem;
  }

  .lp-rm-item {
    --rm-i: 0;
  }

  .lp-rm-mono {
    margin: 0;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.75rem;
    letter-spacing: -0.02em;
  }

  /* Card */
  .lp-rm-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.92fr);
    background: var(--lp-surface);
    border: 1px solid var(--ol-border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--lp-shadow);
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.5s ease,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease,
      border-color 0.2s ease;
    transition-delay: calc(var(--rm-i) * 55ms);
  }

  .lp-rm-card.lp-rm-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .lp-rm-card:hover {
    box-shadow: 0 8px 28px rgba(56, 58, 66, 0.08);
    border-color: color-mix(in oklab, var(--ol-border) 55%, var(--ol-accent));
  }

  .lp-rm-copy {
    padding: 1.4rem 1.5rem 1.55rem;
    min-width: 0;
  }

  .lp-rm-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin-bottom: 0.65rem;
  }

  .lp-rm-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    font-size: 0.65625rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    font-family: ui-monospace, monospace;
  }

  .lp-rm-pill--shipped {
    background: color-mix(in oklab, var(--ol-success) 12%, transparent);
    color: color-mix(in oklab, var(--ol-success) 88%, var(--ol-text));
    border: 1px solid color-mix(in oklab, var(--ol-success) 28%, transparent);
  }

  .lp-rm-pill--progress {
    background: color-mix(in oklab, var(--ol-accent) 10%, transparent);
    color: var(--ol-accent);
    border: 1px solid color-mix(in oklab, var(--ol-accent) 22%, transparent);
  }

  .lp-rm-pill--planned {
    background: color-mix(in oklab, var(--ol-text) 5%, transparent);
    color: var(--ol-text2);
    border: 1px solid color-mix(in oklab, var(--ol-border) 75%, transparent);
  }

  .lp-rm-era {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ol-text2);
    letter-spacing: -0.01em;
  }

  .lp-rm-title {
    margin: 0 0 0.55rem;
    font-size: 1.22rem;
    font-weight: 700;
    letter-spacing: -0.028em;
    line-height: 1.2;
    color: var(--lp-ink);
  }

  .lp-rm-body {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.62;
    color: var(--ol-text2);
  }

  /* Viz column — calm panel like main feat previews */
  .lp-rm-viz {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.35rem 1.25rem;
    background: var(--ol-bg);
    border-left: 1px solid var(--ol-border);
    min-height: 10.5rem;
  }

  .lp-rm-viz-inner {
    width: 100%;
    max-width: 15.5rem;
    padding: 1.1rem 1.15rem 0.85rem;
    background: var(--lp-surface);
    border: 1px solid color-mix(in oklab, var(--ol-border) 88%, transparent);
    border-radius: 0.625rem;
    box-shadow: 0 1px 3px rgba(56, 58, 66, 0.04);
  }

  .lp-rm-viz-cap {
    margin: 0.85rem 0 0;
    padding-top: 0.75rem;
    border-top: 1px solid color-mix(in oklab, var(--ol-border) 65%, transparent);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ol-text3);
  }

  .lp-rm-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.65rem;
  }

  .lp-rm-chip {
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.22rem 0.42rem;
    border-radius: 0.3rem;
    background: transparent;
    border: 1px solid var(--ol-border);
    color: var(--ol-text);
    font-family: ui-monospace, monospace;
  }

  .lp-rm-chip--quiet {
    color: var(--ol-text2);
    border-color: color-mix(in oklab, var(--ol-border) 80%, transparent);
  }

  .lp-rm-wl {
    color: var(--ol-accent);
    margin-bottom: 0.7rem;
  }

  .lp-rm-graph-min {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .lp-rm-graph-min__dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--ol-text3);
    opacity: 0.4;
  }

  .lp-rm-graph-min__hub {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--ol-accent);
    opacity: 0.85;
  }

  .lp-rm-min-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .lp-rm-min-list__li {
    margin: 0;
    padding: 0.38rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ol-text);
    border-radius: 0.35rem;
    border: 1px solid color-mix(in oklab, var(--ol-border) 90%, transparent);
    background: color-mix(in oklab, var(--ol-bg) 65%, var(--lp-surface));
  }

  .lp-rm-min-list__li--accent {
    color: var(--ol-accent);
    border-color: color-mix(in oklab, var(--ol-accent) 22%, var(--ol-border));
    background: color-mix(in oklab, var(--ol-accent) 6%, var(--lp-surface));
  }

  .lp-rm-min-list__li--muted {
    color: var(--ol-text2);
    font-size: 0.71875rem;
  }

  .lp-rm-bars {
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
    margin-bottom: 0.7rem;
  }

  .lp-rm-bar {
    display: block;
    height: 3px;
    border-radius: 2px;
    background: var(--ol-border);
    opacity: 0.85;
  }

  .lp-rm-bar--mid {
    width: 72%;
  }

  .lp-rm-bar--short {
    width: 48%;
  }

  .lp-rm-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .lp-rm-tags span {
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.2rem 0.4rem;
    border-radius: 0.3rem;
    color: var(--ol-accent);
    border: 1px solid color-mix(in oklab, var(--ol-accent) 20%, var(--ol-border));
    background: color-mix(in oklab, var(--ol-accent) 5%, transparent);
    font-family: ui-monospace, monospace;
  }

  .lp-rm-lic__row {
    display: flex;
    gap: 0.45rem;
    margin-bottom: 0.55rem;
  }

  .lp-rm-lic__badge {
    flex: 1;
    text-align: center;
    font-size: 0.6875rem;
    font-weight: 700;
    font-family: ui-monospace, monospace;
    padding: 0.45rem 0.35rem;
    border-radius: 0.35rem;
    border: 1px solid var(--ol-border);
    color: var(--ol-text);
  }

  .lp-rm-lic__hint {
    text-align: center;
    color: var(--ol-text2);
    font-size: 0.6875rem;
  }

  .lp-rm-find {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.42rem 0.55rem;
    border-radius: 0.4rem;
    border: 1px solid var(--ol-border);
    background: color-mix(in oklab, var(--ol-bg) 40%, var(--lp-surface));
    margin-bottom: 0.45rem;
  }

  .lp-rm-find__kbd {
    font-size: 0.625rem;
    color: var(--ol-text3);
  }

  .lp-rm-find__ph {
    font-size: 0.75rem;
    color: var(--ol-text2);
    flex: 1;
    min-width: 0;
  }

  .lp-rm-find__sub {
    text-align: center;
    color: var(--ol-accent);
    font-size: 0.65625rem;
    opacity: 0.9;
  }

  .lp-rm-link-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.45rem;
    padding: 0.25rem 0;
  }

  .lp-rm-link-row__a {
    width: 1.1rem;
    height: 1.5rem;
    border-radius: 0.2rem;
    border: 1.5px solid var(--ol-text3);
    opacity: 0.5;
  }

  .lp-rm-link-row__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--ol-border), var(--ol-accent) 50%, var(--ol-border));
    opacity: 0.55;
  }

  .lp-rm-link-row__b {
    width: 1.5rem;
    height: 0.95rem;
    border-radius: 0.65rem 0.65rem 0.2rem 0.2rem;
    border: 1.5px solid var(--ol-text3);
    opacity: 0.45;
  }

  .lp-rm-grid-ico {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.25rem;
    max-width: 6.5rem;
    margin: 0 auto;
  }

  .lp-rm-grid-ico span {
    aspect-ratio: 1;
    border-radius: 0.2rem;
    background: var(--ol-border);
    opacity: 0.35;
  }

  .lp-rm-grid-ico__on {
    opacity: 1;
    background: color-mix(in oklab, var(--ol-accent) 18%, var(--ol-bg));
    border: 1px solid color-mix(in oklab, var(--ol-accent) 30%, var(--ol-border));
  }

  @media (max-width: 52rem) {
    .lp-rm-card {
      grid-template-columns: 1fr;
    }

    .lp-rm-viz {
      border-left: none;
      border-top: 1px solid var(--ol-border);
      min-height: auto;
      padding: 1.1rem 1rem 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-rm-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined' || typeof document === 'undefined') return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const cards = document.querySelectorAll('.lp-rm-card');
    if (!cards.length) return;
    if (reduce) {
      cards.forEach((c) => c.classList.add('lp-rm-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('lp-rm-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -7% 0px' },
    );
    cards.forEach((c) => io.observe(c));
  })();
</script>
