---
import MarketingPageLayout from '@/layouts/marketing_page_layout.astro';
---

<MarketingPageLayout
  title="Pricing | kuku"
  description="Public beta — full Pro access for every user. Bring your own Gemini key, or wait for managed plans at launch."
  wide
>
  <div class="lp-pr" id="lp-pricing">
    <header class="lp-pr-head">
      <h1 class="lp-pr-title" data-i18n="pr.title">Simple Pricing</h1>
    </header>

    <section class="lp-pr-hero-grid">
      <article class="lp-pr-hero lp-pr-hero--beta">
        <p class="lp-pr-hero__badge" data-i18n="pr.beta.badge">Public Beta</p>
        <h2 class="lp-pr-hero__headline" data-i18n="pr.beta.headline">
          Everyone is on Pro right now
        </h2>
        <p class="lp-pr-hero__text" data-i18n="pr.beta.text">
          While kuku is in public beta, every user automatically gets full Pro-tier access. No
          account upgrade, no billing — just download and use every AI feature.
        </p>
        <p class="lp-pr-hero__note" data-i18n="pr.beta.note">
          Managed plans with usage limits and pricing will be announced at general availability.
        </p>
      </article>

      <article class="lp-pr-hero lp-pr-hero--byok">
        <p class="lp-pr-hero__badge">BYoK</p>
        <h2 class="lp-pr-hero__headline" data-i18n="pr.byok.headline">Bring your own Gemini key</h2>
        <p class="lp-pr-hero__text" data-i18n="pr.byok.text">
          Prefer to run AI on your own provider account? Drop your Gemini API key into Settings →
          AI. kuku routes every request through your key, so you pay Google directly and nothing
          flows through our billing.
        </p>
        <p class="lp-pr-hero__note" data-i18n="pr.byok.note">
          Gemini is the only supported provider today. OpenAI, Anthropic, and local LLMs are on the
          roadmap.
        </p>
      </article>
    </section>
  </div>
</MarketingPageLayout>

<style>
  .lp-pr {
    --lp-pr-card-border: color-mix(in oklab, var(--ol-border) 90%, transparent);
    --lp-pr-card-border-hover: color-mix(in oklab, var(--ol-border2) 74%, transparent);
    padding-bottom: 1rem;
  }

  .lp-pr-head {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto 3rem;
  }

  .lp-pr-title {
    margin: 0;
    font-size: clamp(1.875rem, 4.5vw, 2.375rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--ol-text);
  }

  .lp-pr-hero-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .lp-pr-hero {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border: 1px solid var(--lp-pr-card-border);
    border-radius: 1rem;
    background: var(--lp-surface);
    box-shadow: var(--lp-shadow);
    transition:
      border-color 0.22s ease,
      box-shadow 0.22s ease;
  }

  .lp-pr-hero:hover {
    border-color: var(--lp-pr-card-border-hover);
  }

  .lp-pr-hero--beta {
    border-color: color-mix(in oklab, var(--ol-accent) 32%, var(--ol-border));
    background: color-mix(in oklab, var(--ol-accent) 5%, var(--lp-surface));
  }

  .lp-pr-hero__badge {
    align-self: flex-start;
    margin: 0 0 1rem;
    padding: 0.28rem 0.7rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    color: var(--ol-accent);
    background: color-mix(in oklab, var(--ol-accent) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--ol-accent) 22%, transparent);
    border-radius: 999px;
  }

  .lp-pr-hero--byok .lp-pr-hero__badge {
    color: var(--ol-text2);
    background: color-mix(in oklab, var(--ol-text) 6%, transparent);
    border-color: color-mix(in oklab, var(--ol-border) 80%, transparent);
  }

  .lp-pr-hero__headline {
    margin: 0 0 0.75rem;
    font-size: clamp(1.25rem, 1.8vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.25;
    color: var(--ol-text);
  }

  .lp-pr-hero__text {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ol-text2);
  }

  .lp-pr-hero__note {
    margin: auto 0 0;
    padding-top: 0.85rem;
    border-top: 1px dashed color-mix(in oklab, var(--ol-border) 70%, transparent);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--ol-text3);
  }

  @media (max-width: 52rem) {
    .lp-pr-hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
