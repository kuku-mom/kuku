<script is:inline>
  (() => {
    const root = document.getElementById('lp-pricing');
    if (!root) return;

    const monthlyBtn = document.getElementById('lp-pr-bill-monthly');
    const yearlyBtn = document.getElementById('lp-pr-bill-yearly');

    const syncBillingA11y = () => {
      const period = root.dataset.billing;
      if (!period) return;
      root.querySelectorAll('.lp-pr-amount-stack .lp-pr-card__amount').forEach((el) => {
        const show = el.getAttribute('data-show');
        el.setAttribute('aria-hidden', show === period ? 'false' : 'true');
      });
      root.querySelectorAll('.lp-pr-save-stack__layer').forEach((el) => {
        const show = el.getAttribute('data-show');
        if (show === 'monthly') {
          el.setAttribute('aria-hidden', 'true');
        } else {
          el.setAttribute('aria-hidden', period === 'yearly' ? 'false' : 'true');
        }
      });
    };

    const setBilling = (period) => {
      root.dataset.billing = period;
      monthlyBtn?.setAttribute('aria-pressed', period === 'monthly' ? 'true' : 'false');
      yearlyBtn?.setAttribute('aria-pressed', period === 'yearly' ? 'true' : 'false');
      syncBillingA11y();
    };

    monthlyBtn?.addEventListener('click', () => setBilling('monthly'));
    yearlyBtn?.addEventListener('click', () => setBilling('yearly'));
    syncBillingA11y();
  })();
</script>
