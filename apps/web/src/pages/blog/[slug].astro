---
import MarketingPageLayout from '@/layouts/marketing_page_layout.astro';
import { blogPosts, getBlogPost } from '@/data/blog_posts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = slug ? getBlogPost(slug) : undefined;
if (!post) {
  return Astro.redirect('/blog');
}

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<MarketingPageLayout title={`${post.title} | kuku`} description={post.excerpt} wide>
  <article class="lp-blog-post" itemscope itemtype="https://schema.org/BlogPosting">
    <a class="lp-blog-post__back" href="/blog" data-i18n="blog.back">← Blog</a>

    <header class="lp-blog-post__head">
      <time class="lp-blog-post__date" datetime={post.date} itemprop="datePublished">
        {dateFmt.format(new Date(post.date + 'T12:00:00'))}
      </time>
      <h1 class="lp-blog-post__title" itemprop="headline" data-i18n={`blog.${post.slug}.title`}>
        {post.title}
      </h1>
      <p class="lp-blog-post__by">
        <span itemprop="author" itemscope itemtype="https://schema.org/Person">
          <span itemprop="name">{post.author}</span>
        </span>
      </p>
    </header>

    <figure class="lp-blog-post__figure">
      <img
        class="lp-blog-post__img"
        src={post.image}
        alt={post.imageAlt}
        width={2560}
        height={1080}
        loading="eager"
        decoding="async"
        itemprop="image"
      />
    </figure>

    <div class="lp-blog-post__prose">
      {
        post.body.map((para, i) => (
          <p itemprop="articleBody" data-i18n={`blog.${post.slug}.body${i}`}>
            {para}
          </p>
        ))
      }
    </div>
  </article>
</MarketingPageLayout>

<style>
  .lp-blog-post {
    --lp-bp-border: #e5e7eb;
    --lp-bp-ink: #0a0a0a;
    --lp-bp-muted: #6b7280;
    --lp-bp-faint: #9ca3af;

    max-width: 42rem;
    margin: 0 auto;
    padding-bottom: 2rem;
  }

  .lp-blog-post__back {
    display: inline-block;
    margin: 0 0 1.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--lp-bp-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .lp-blog-post__back:hover {
    color: var(--lp-bp-ink);
  }

  .lp-blog-post__head {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .lp-blog-post__date {
    display: block;
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    color: var(--lp-bp-faint);
  }

  .lp-blog-post__title {
    margin: 0 0 0.65rem;
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.25;
    color: var(--lp-bp-ink);
  }

  .lp-blog-post__by {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--lp-bp-faint);
  }

  .lp-blog-post__figure {
    position: relative;
    margin: 0 0 1.75rem;
    width: 100%;
    aspect-ratio: 21 / 9;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--lp-bp-border);
    background: var(--ol-bg2);
    box-shadow: none;
  }

  .lp-blog-post__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.35s ease;
  }

  .lp-blog-post__figure:hover .lp-blog-post__img {
    transform: scale(1.006);
    filter: brightness(1.03);
  }

  .lp-blog-post__prose {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--lp-bp-muted);
  }

  .lp-blog-post__prose p {
    margin: 0 0 1rem;
  }

  .lp-blog-post__prose p:last-child {
    margin-bottom: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-blog-post__img {
      transition: none;
    }

    .lp-blog-post__figure:hover .lp-blog-post__img {
      transform: none;
      filter: none;
    }
  }
</style>
