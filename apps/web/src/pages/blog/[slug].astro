---
import MarketingPageLayout from '@/layouts/marketing_page_layout.astro';
import { getCollection, render } from 'astro:content';
import { SUPPORTED_LANGS, type SupportedLang } from '@/content.config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const bySlug = new Map<string, typeof posts>();
  for (const post of posts) {
    const existing = bySlug.get(post.data.slug) ?? [];
    existing.push(post);
    bySlug.set(post.data.slug, existing);
  }
  return [...bySlug.entries()].map(([slug, variants]) => ({
    params: { slug },
    props: { variants },
  }));
}

const { variants } = Astro.props;
const byLang = new Map<SupportedLang, (typeof variants)[number]>();
for (const v of variants) byLang.set(v.data.lang, v);

const anchor = byLang.get('en') ?? variants[0];
const rendered: {
  lang: SupportedLang;
  variant: typeof anchor;
  Content: Awaited<ReturnType<typeof render>>['Content'];
}[] = [];
for (const lang of SUPPORTED_LANGS) {
  const variant = byLang.get(lang) ?? anchor;
  const { Content } = await render(variant);
  rendered.push({ lang, variant, Content });
}

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<MarketingPageLayout title={`${anchor.data.title} | kuku`} description={anchor.data.excerpt} wide>
  <article class="lp-blog-post" itemscope itemtype="https://schema.org/BlogPosting">
    <a class="lp-blog-post__back" href="/blog" data-i18n="blog.back">← Blog</a>

    <header class="lp-blog-post__head">
      <time class="lp-blog-post__date" datetime={anchor.data.date} itemprop="datePublished">
        {dateFmt.format(new Date(anchor.data.date + 'T12:00:00'))}
      </time>
      {
        rendered.map(({ lang, variant }) => (
          <div data-lang-block={lang}>
            <h1 class="lp-blog-post__title" itemprop="headline">
              {variant.data.title}
            </h1>
          </div>
        ))
      }
      <p class="lp-blog-post__by">
        <span itemprop="author" itemscope itemtype="https://schema.org/Person">
          <span itemprop="name">{anchor.data.author}</span>
        </span>
      </p>
    </header>

    <figure class="lp-blog-post__figure">
      <img
        class="lp-blog-post__img"
        src={anchor.data.image}
        alt={anchor.data.imageAlt}
        width={2560}
        height={1080}
        loading="eager"
        decoding="async"
        itemprop="image"
      />
    </figure>

    {
      rendered.map(({ lang, Content }) => (
        <div class="lp-blog-post__prose" data-lang-block={lang} itemprop="articleBody">
          <Content />
        </div>
      ))
    }
  </article>
</MarketingPageLayout>

<style>
  .lp-blog-post {
    --lp-bp-border: var(--ol-border);
    --lp-bp-ink: var(--ol-text);
    --lp-bp-muted: var(--ol-text2);
    --lp-bp-faint: var(--ol-text3);

    max-width: 42rem;
    margin: 0 auto;
    padding-bottom: 2rem;
  }

  .lp-blog-post__back {
    display: inline-block;
    margin: 0 0 1.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--lp-bp-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .lp-blog-post__back:hover {
    color: var(--lp-bp-ink);
  }

  .lp-blog-post__head {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .lp-blog-post__date {
    display: block;
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    color: var(--lp-bp-faint);
  }

  .lp-blog-post__title {
    margin: 0 0 0.65rem;
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.25;
    color: var(--lp-bp-ink);
  }

  .lp-blog-post__by {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--lp-bp-faint);
  }

  .lp-blog-post__figure {
    position: relative;
    margin: 0 0 1.75rem;
    width: 100%;
    aspect-ratio: 21 / 9;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--lp-bp-border);
    background: var(--ol-bg2);
    box-shadow: none;
  }

  .lp-blog-post__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.35s ease;
  }

  .lp-blog-post__figure:hover .lp-blog-post__img {
    transform: scale(1.006);
    filter: brightness(1.03);
  }

  .lp-blog-post__prose {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--lp-bp-muted);
  }

  .lp-blog-post__prose :global(p) {
    margin: 0 0 1rem;
  }

  .lp-blog-post__prose :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-blog-post__img {
      transition: none;
    }

    .lp-blog-post__figure:hover .lp-blog-post__img {
      transform: none;
      filter: none;
    }
  }
</style>
