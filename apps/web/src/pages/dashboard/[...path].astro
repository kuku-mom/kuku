---
import DashboardApp from '@/components/dashboard/dashboard_app';
import BaseLayout from '@/layouts/base_layout.astro';
import {
  dashboardPathToRoute,
  dashboardRoutePaths,
  type DashboardRoute,
} from '@/lib/api/dashboard';

export function getStaticPaths() {
  return [
    { params: { path: undefined } },
    ...dashboardRoutePaths.map((path) => ({ params: { path } })),
  ];
}

function getInitialRoute(path: string | undefined): DashboardRoute {
  return dashboardPathToRoute(path);
}

const initialRoute = getInitialRoute(Astro.params.path);
---

<BaseLayout title="Dashboard | kuku" description="Manage your kuku account.">
  <meta slot="head" name="robots" content="noindex,nofollow" />
  <DashboardApp initialRoute={initialRoute} client:load />
</BaseLayout>
