---
import MarketingPageLayout from '@/layouts/marketing_page_layout.astro';
import { getCollection } from 'astro:content';
import { SUPPORTED_LANGS, type SupportedLang } from '@/content.config';

const posts = await getCollection('blog');

// Group by slug so each card renders all language variants stacked.
const bySlug = new Map<string, typeof posts>();
for (const post of posts) {
  const existing = bySlug.get(post.data.slug) ?? [];
  existing.push(post);
  bySlug.set(post.data.slug, existing);
}

type PostVariants = (typeof posts)[number];

const groups: {
  slug: string;
  date: string;
  image: string;
  variants: Map<SupportedLang, PostVariants>;
}[] = [];
for (const [slug, variants] of bySlug) {
  const byLang = new Map<SupportedLang, PostVariants>();
  for (const v of variants) byLang.set(v.data.lang, v);
  const anchor = byLang.get('en') ?? variants[0];
  groups.push({
    slug,
    date: anchor.data.date,
    image: anchor.data.image,
    variants: byLang,
  });
}

groups.sort((a, b) => (a.date < b.date ? 1 : -1));

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<MarketingPageLayout
  title="Blog | kuku"
  description="Updates, thoughts, and announcements from the kuku team."
  wide
>
  <div class="lp-blog">
    <header class="lp-blog__head">
      <h1 class="lp-blog__title" data-i18n="blog.title">Blog</h1>
      <p class="lp-blog__sub" data-i18n="blog.sub">Updates, thoughts, and announcements.</p>
    </header>

    <div class="lp-blog__list">
      {
        groups.map((group) => {
          const firstVariant = group.variants.get('en') ?? [...group.variants.values()][0];
          return (
            <article class="lp-blog-card">
              <a
                class="lp-blog-card__media"
                href={`/blog/${group.slug}`}
                tabindex="-1"
                aria-hidden="true"
              >
                <img
                  class="lp-blog-card__img"
                  src={group.image}
                  alt=""
                  width={2560}
                  height={1080}
                  loading="lazy"
                  decoding="async"
                />
              </a>
              <div class="lp-blog-card__body">
                <time class="lp-blog-card__date" datetime={group.date}>
                  {dateFmt.format(new Date(group.date + 'T12:00:00'))}
                </time>
                {SUPPORTED_LANGS.map((lang) => {
                  const variant = group.variants.get(lang) ?? firstVariant;
                  return (
                    <div data-lang-block={lang}>
                      <h2 class="lp-blog-card__heading">
                        <a class="lp-blog-card__title-link" href={`/blog/${group.slug}`}>
                          {variant.data.title}
                        </a>
                      </h2>
                      <p class="lp-blog-card__excerpt">{variant.data.excerpt}</p>
                    </div>
                  );
                })}
                <p class="lp-blog-card__by">
                  <span data-i18n="blog.by">By</span> {firstVariant.data.author}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</MarketingPageLayout>

<style>
  .lp-blog {
    --lp-blog-border: var(--ol-border);
    --lp-blog-ink: var(--ol-text);
    --lp-blog-muted: var(--ol-text2);
    --lp-blog-faint: var(--ol-text3);

    max-width: 42rem;
    margin: 0 auto;
    padding-bottom: 1rem;
  }

  .lp-blog__head {
    text-align: left;
    margin-bottom: 2.75rem;
  }

  .lp-blog__title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.875rem, 4.5vw, 2.375rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--lp-blog-ink);
  }

  .lp-blog__sub {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--lp-blog-muted);
  }

  .lp-blog__list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .lp-blog-card {
    background: var(--lp-surface);
    border: 1px solid var(--lp-blog-border);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: none;
    transition: border-color 0.22s ease;
  }

  .lp-blog-card:hover {
    border-color: color-mix(in oklab, var(--lp-blog-border) 82%, var(--lp-blog-ink));
  }

  .lp-blog-card__media {
    display: block;
    position: relative;
    width: 100%;
    margin: 0;
    line-height: 0;
    background: var(--ol-bg2);
    outline: none;
    aspect-ratio: 21 / 9;
    overflow: hidden;
  }

  .lp-blog-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.35s ease;
  }

  .lp-blog-card__media:hover .lp-blog-card__img,
  .lp-blog-card__media:focus-visible .lp-blog-card__img {
    transform: scale(1.006);
    filter: brightness(1.03);
  }

  .lp-blog-card__body {
    padding: 1.35rem 1.35rem 1.5rem;
  }

  .lp-blog-card__date {
    display: block;
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    color: var(--lp-blog-faint);
  }

  .lp-blog-card__heading {
    margin: 0 0 0.65rem;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.3;
  }

  .lp-blog-card__title-link {
    color: var(--lp-blog-ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .lp-blog-card__title-link:hover {
    color: color-mix(in oklab, var(--lp-blog-ink) 72%, var(--ol-accent));
  }

  .lp-blog-card__excerpt {
    margin: 0 0 1.1rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--lp-blog-muted);
  }

  .lp-blog-card__by {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--lp-blog-faint);
  }

  @media (max-width: 40rem) {
    .lp-blog__list {
      gap: 2rem;
    }

    .lp-blog-card__body {
      padding: 1.15rem 1.1rem 1.35rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-blog-card__img {
      transition: none;
    }

    .lp-blog-card__media:hover .lp-blog-card__img,
    .lp-blog-card__media:focus-visible .lp-blog-card__img {
      transform: none;
      filter: none;
    }
  }
</style>
