---
import AuthNavLink from '@/components/auth_nav_link';
import BaseLayout from '@/layouts/base_layout.astro';
---

<BaseLayout title="kuku" description="An AI-native Markdown workspace for connected thinking.">
  <main class="page-shell">
    <header class="site-header" aria-label="Primary">
      <a class="brand" href="/" aria-label="kuku home">
        <img src="/logo.svg" alt="" />
        <span>kuku</span>
      </a>
      <nav class="nav-links" aria-label="Main navigation">
        <AuthNavLink client:load />
      </nav>
    </header>

    <section class="hero" aria-labelledby="hero-title">
      <p class="eyebrow">WORK IN PROGRESS</p>
      <h1 id="hero-title">HERO TITLE</h1>
      <p class="hero-copy">HERO COPY</p>
      <div class="hero-actions" id="download">
        <a class="primary-link" href="https://www.kuku.mom">Download for macOS</a>
      </div>
    </section>
  </main>
</BaseLayout>
