  .lp-gh-badge svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .lp-yc-copy {
    color: inherit;
  }

  .lp-yc-link {
    position: relative;
    display: inline-block;
    color: inherit;
    font-weight: inherit;
    font-size: inherit;
    text-decoration: none;
  }

  .lp-yc-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.08em;
    height: 1px;
    background: color-mix(in oklab, currentColor 82%, transparent);
    transform: scaleX(0);
    transform-origin: left center;
    opacity: 0.8;
    transition:
      transform 0.26s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.22s ease;
  }

  .lp-yc-badge:hover .lp-yc-link::after,
  .lp-yc-badge:focus-visible .lp-yc-link::after {
    transform: scaleX(1);
    opacity: 1;
  }

  .lp-yc-arrow {
    width: 0.8rem;
    height: 0.8rem;
    color: inherit;
    opacity: 0.42;
    margin-left: 0.02rem;
    transition:
      transform 0.2s ease,
      opacity 0.18s ease;
    flex-shrink: 0;
  }

  .lp-yc-badge:hover .lp-yc-arrow {
    transform: translate(2px, -2px);
    opacity: 0.65;
  }

  .lp-hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    overflow: visible;
