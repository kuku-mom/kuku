    .lp-screenshot-body {
      --lp-mockup-scale: 0.54;
      height: clamp(21rem, 94vw, 27rem);
    }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined' || typeof document === 'undefined') return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mdVaultCodeHighlightedHtml =
      '<span class="lp-md-syn-kw">const</span> g = ' +
      '<span class="lp-md-syn-kw">await</span> ' +
      '<span class="lp-md-syn-fn">indexVault</span>(' +
      '<span class="lp-md-syn-str">root</span>, { ' +
      '<span class="lp-md-syn-key">validateWikilinks</span>: ' +
      '<span class="lp-md-syn-kw">true</span> });';

    function delayMs(ms) {
      return new Promise((res) => window.setTimeout(res, ms));
    }

    function typeText(el, text, ms) {
      return new Promise((resolve) => {
        if (!el) {
          resolve();
          return;
        }
        let i = 0;
        function tick() {
          if (i <= text.length) {
            el.textContent = text.slice(0, i);
            i++;
            window.setTimeout(tick, ms);
          } else resolve();
        }
        tick();
      });
    }

    function appendType(el, suffix, ms) {
      return new Promise((resolve) => {
        if (!el) {
          resolve();
          return;
        }
        const base = el.textContent || '';
        let j = 0;
        function tick() {
          if (j <= suffix.length) {
            el.textContent = base + suffix.slice(0, j);
            j++;
            window.setTimeout(tick, ms);
          } else resolve();
        }
        tick();
      });
    }

    function backspaceChars(el, count, ms) {
      return new Promise((resolve) => {
        if (!el || count <= 0) {
          resolve();
          return;
        }
        let left = count;
        function tick() {
          if (left <= 0) {
            resolve();
            return;
          }
          const text = el.textContent || '';
          el.textContent = text.slice(0, Math.max(0, text.length - 1));
          left--;
          window.setTimeout(tick, ms);
        }
        tick();
      });
    }

    function whenVisible(el, fn) {
      if (!el) return;
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              fn();
              io.disconnect();
            }
          }
        },
        { threshold: 0.22, rootMargin: '0px 0px -6% 0px' },
      );
      io.observe(el);
    }

    const searchRoot = document.getElementById('lp-demo-search');
    whenVisible(searchRoot, () => {
      const q = (searchRoot && searchRoot.getAttribute('data-lp-query')) || '';
      const typedEl = searchRoot && searchRoot.querySelector('.lp-fv-search-typed');
      const ph = searchRoot && searchRoot.querySelector('.lp-fv-search-placeholder');
      const hit = searchRoot && searchRoot.querySelector('.lp-fv-search-hit');
      if (!typedEl || !hit) return;

      const revealHit = () => hit.classList.add('lp-fv-search-hit--show');

      if (reduce) {
        typedEl.textContent = q;
        if (ph) ph.classList.add('lp-fv-search-ph-hide');
        revealHit();
        return;
      }

      let i = 0;
      const step = 42;
      function tick() {
        if (i <= q.length) {
          typedEl.textContent = q.slice(0, i);
          if (i > 0 && ph) ph.classList.add('lp-fv-search-ph-hide');
          i++;
          window.setTimeout(tick, step);
        } else {
          revealHit();
        }
      }
      tick();
    });

    const sess = document.getElementById('lp-demo-sessions');
    whenVisible(sess, () => {
      if (!sess) return;
      if (reduce) {
        sess.classList.add('lp-sess-anim');
        sess.querySelector('.lp-fv-pill-now')?.classList.add('lp-pill-pulse');
        return;
      }
      window.setTimeout(() => sess.classList.add('lp-sess-anim'), 160);
      window.setTimeout(
        () => sess.querySelector('.lp-fv-pill-now')?.classList.add('lp-pill-pulse'),
        720,
      );
    });

    const prompts = document.getElementById('lp-demo-prompts');
    whenVisible(prompts, () => {
      if (!prompts) return;
      const chips = [...prompts.querySelectorAll('.lp-fv-chip-btn')];
      if (!chips.length) return;
      let idx = 0;
      function setActive(i) {
        idx = ((i % chips.length) + chips.length) % chips.length;
        chips.forEach((c, j) => c.classList.toggle('lp-chip-active', j === idx));
      }
      setActive(0);
      chips.forEach((c, i) => {
        c.addEventListener('click', () => setActive(i));
      });
      let cycleTimer = null;
      function startCycle() {
        if (reduce) return;
        if (cycleTimer) window.clearInterval(cycleTimer);
        cycleTimer = window.setInterval(() => setActive(idx + 1), 3000);
      }
      function stopCycle() {
        if (cycleTimer) {
          window.clearInterval(cycleTimer);
          cycleTimer = null;
        }
      }
      prompts.addEventListener('mouseenter', stopCycle);
      prompts.addEventListener('mouseleave', startCycle);
      startCycle();
    });

    const graph = document.getElementById('lp-demo-graph');
    whenVisible(graph, () => {
      if (!graph) return;
      graph.classList.add('lp-graph-live');
      if (reduce) return;
      graph.querySelectorAll('line.lp-g-edge').forEach((ln, i) => {
        ln.style.transitionDelay = `${i * 0.02}s`;
      });
      graph
        .querySelectorAll('.lp-g-hub--main, .lp-g-hub--sec, .lp-g-hub--ter, .lp-g-hub--mini')
        .forEach((h, i) => {
          h.style.animationDelay = `${0.05 + i * 0.1}s`;
        });
      graph.querySelectorAll('circle.lp-g-node').forEach((c, i) => {
        c.style.animationDelay = `${0.16 + i * 0.028}s`;
      });
      graph.querySelectorAll('.lp-g-lbl').forEach((t, i) => {
        t.style.transitionDelay = `${0.35 + i * 0.018}s`;
      });
    });

    const md = document.getElementById('lp-demo-md');
    whenVisible(md, () => {
      if (!md) return;
      const row0 = md.querySelector('[data-lp-md-row="0"]');
      const row1 = md.querySelector('[data-lp-md-row="1"]');
      const wrap0 = md.querySelector('[data-lp-md-wrap="0"]');
      const wrap1 = md.querySelector('[data-lp-md-wrap="1"]');
      const typed0 = row0 && row0.querySelector('[data-lp-md-typed]');
      const typed1 = row1 && row1.querySelector('[data-lp-md-typed]');
      const caret = document.getElementById('lp-md-singleton-caret');
      const taskWrap = md.querySelector('[data-lp-task-line]');
      const taskBox = taskWrap && taskWrap.querySelector('.lp-fv-task-box');
      const slashPop = document.getElementById('lp-md-slash-pop');
      const slashItems = slashPop ? [...slashPop.querySelectorAll('[data-lp-slash-i]')] : [];
      const aiCodePanel = document.getElementById('lp-md-ai-code');
      const codeTextEl = document.getElementById('lp-md-code-text');
      const codeCaret = document.getElementById('lp-md-code-caret');
      const codeWrapEl = document.getElementById('lp-md-code-wrap');
      const aiStatusEl = document.getElementById('lp-md-ai-status');

      function setSlashActive(i) {
        slashItems.forEach((el) =>
          el.classList.toggle(
            'lp-md-slash-item--act',
            Number(el.getAttribute('data-lp-slash-i')) === i,
          ),
        );
      }

      function applyVaultCodeHighlight() {
        if (codeWrapEl) codeWrapEl.innerHTML = mdVaultCodeHighlightedHtml;
      }

      function caretOn() {
        if (caret) caret.classList.add('lp-md-caret--on');
      }

      function caretOff() {
        if (caret) caret.classList.remove('lp-md-caret--on');
      }

      async function runMd() {
        md.classList.add('lp-md-live');
        if (caret && wrap0 && !wrap0.contains(caret)) wrap0.appendChild(caret);
        if (reduce) {
          if (typed0) typed0.textContent = '# Q1 Planning';
          if (typed1) {
            typed1.innerHTML =
              'Next: <span class="lp-fv-md-bold">triage open risks</span> after sync.';
          }
          md.classList.add('lp-md-show-line2', 'lp-md-rest-visible', 'lp-md-code-live');
          applyVaultCodeHighlight();
          if (aiCodePanel) aiCodePanel.setAttribute('aria-hidden', 'false');
          if (aiStatusEl) aiStatusEl.textContent = 'done';
          caretOff();
          if (codeCaret) codeCaret.classList.remove('lp-md-caret--on');
          if (taskWrap && taskBox) {
            taskWrap.classList.add('lp-task-checked');
            taskBox.textContent = '[x]';
          }
          return;
        }

        caretOn();
        if (row0) row0.classList.add('lp-md-row--active');
        await typeText(typed0, '# Q1 Planning', 36);
        if (row0) row0.classList.remove('lp-md-row--active');
        caretOff();
        await delayMs(240);

        md.classList.add('lp-md-show-line2');
        await delayMs(400);
        if (caret && wrap1) wrap1.appendChild(caret);
        caretOn();
        if (row1) row1.classList.add('lp-md-row--active');
        await typeText(typed1, 'Next: /', 28);
        md.classList.add('lp-md-slash-open');
        if (slashPop) slashPop.setAttribute('aria-hidden', 'false');
        const slashSeq = [0, 1, 2, 3, 4, 1, 4];
        for (const slashIndex of slashSeq) {
          setSlashActive(slashIndex);
          await delayMs(220);
        }
        await delayMs(320);
        md.classList.remove('lp-md-slash-open');
        md.classList.add('lp-md-code-live');
        if (slashPop) slashPop.setAttribute('aria-hidden', 'true');
        if (aiCodePanel) aiCodePanel.setAttribute('aria-hidden', 'false');
        await delayMs(90);

        caretOff();
        if (codeCaret) codeCaret.classList.add('lp-md-caret--on');
        if (typed1) typed1.textContent = 'Next: ';
        if (aiStatusEl) aiStatusEl.textContent = 'editing…';

        if (codeTextEl) {
          await typeText(codeTextEl, 'const g = await indexVault(root);', 17);
          await delayMs(420);
          await backspaceChars(codeTextEl, 2, 32);
          await backspaceChars(codeTextEl, 4, 28);
          await delayMs(160);
          await appendType(codeTextEl, 'root, { validateWikilinks: true }', 15);
          await appendType(codeTextEl, ');', 20);
        }

        if (codeCaret) codeCaret.classList.remove('lp-md-caret--on');
        applyVaultCodeHighlight();
        if (aiStatusEl) aiStatusEl.textContent = 'done';

        await appendType(typed1, 'triage open risks after sync.', 20);
        if (row1) row1.classList.remove('lp-md-row--active');
        if (typed1) {
          typed1.innerHTML =
            'Next: <span class="lp-fv-md-bold">triage open risks</span> after sync.';
        }

        md.classList.add('lp-md-rest-visible');
        await delayMs(520);
        if (taskWrap && taskBox) {
          taskWrap.classList.add('lp-task-checked');
          taskBox.textContent = '[x]';
        }
      }

      runMd();
    });

    const agent = document.getElementById('lp-demo-agent');
    whenVisible(agent, () => {
      if (!agent) return;
      const typed = agent.querySelector('[data-lp-ai-typed]');
      const caretAi = agent.querySelector('[data-lp-ai-caret]');
      const stepEls = ['search', 'hit', 'read', 'index', 'ready'].map((k) =>
        agent.querySelector(`[data-lp-ai-step="${k}"]`),
      );
      const q = 'What are the OKR risks in Q1?';

      async function typePrompt() {
        if (!typed) return;
        for (let i = 0; i <= q.length; i++) {
          typed.textContent = q.slice(0, i);
          await delayMs(26);
        }
      }

      function resetSteps() {
        stepEls.forEach((el) => {
          if (!el) return;
          el.classList.remove('lp-ai-step--in', 'lp-ai-step--spin-done');
        });
        if (caretAi) caretAi.classList.remove('lp-ai-caret--off');
        if (typed) typed.textContent = '';
      }

      async function runAiCycle() {
        resetSteps();
        if (reduce) {
          if (typed) typed.textContent = q;
          if (caretAi) caretAi.classList.add('lp-ai-caret--off');
          stepEls.forEach((el) => {
            if (el) el.classList.add('lp-ai-step--in', 'lp-ai-step--spin-done');
          });
          return;
        }
        await typePrompt();
        if (caretAi) caretAi.classList.add('lp-ai-caret--off');
        await delayMs(200);
        if (stepEls[0]) stepEls[0].classList.add('lp-ai-step--in');
        await delayMs(780);
        if (stepEls[0]) stepEls[0].classList.add('lp-ai-step--spin-done');
        if (stepEls[1]) stepEls[1].classList.add('lp-ai-step--in');
        await delayMs(400);
        if (stepEls[2]) stepEls[2].classList.add('lp-ai-step--in');
        await delayMs(420);
        if (stepEls[3]) stepEls[3].classList.add('lp-ai-step--in');
        await delayMs(360);
        if (stepEls[4]) stepEls[4].classList.add('lp-ai-step--in');
      }

      async function loopAi() {
        await runAiCycle();
        if (reduce) return;
        await delayMs(3600);
        loopAi();
      }

      loopAi();
    });

    const localEl = document.getElementById('lp-demo-local');
    whenVisible(localEl, () => {
      if (localEl) localEl.classList.add('lp-local-live');
    });
  })();
</script>
