    color: var(--ol-text2);
  }

  .lp-download-soon {
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--lp-faint);
  }

  /* ── App Screenshot ── */
  .lp-screenshot-wrap {
    position: relative;
    z-index: 0;
    width: min(100%, 96rem);
    margin: clamp(2.25rem, 1.25rem + 2.5vw, 3.5rem) auto 0;
    padding: 0 clamp(0.75rem, 0.35rem + 1.5vw, 2rem);
    /* Hero is center-aligned; app preview text must stay left-aligned like the real app */
