<style>
  /* ── One Light (same tokens as app_mockup.astro) ── */
  .lp-root {
    --ol-bg: var(--theme-ol-bg);
    --ol-bg2: var(--theme-ol-bg2);
    --ol-bg3: var(--theme-ol-bg3);
    --ol-border: var(--theme-ol-border);
    --ol-border2: var(--theme-ol-border2);
    --ol-text: var(--theme-ol-text);
    --ol-text2: var(--theme-ol-text2);
    --ol-text3: var(--theme-ol-text3);
    --ol-accent: var(--theme-ol-accent);
    --ol-accent-dim: var(--theme-ol-accent-dim);
    --ol-sel: var(--theme-ol-sel);
    --ol-inact: var(--theme-ol-inact);
    --ol-success: var(--theme-ol-success);
    --ol-error: var(--theme-ol-error);
    --ol-on-ink: var(--theme-ol-on-ink);
    --ol-ink-hover: var(--theme-ol-ink-hover);

    --lp-bg0: var(--ol-bg);
    --lp-bg1: var(--ol-bg2);
    --lp-surface: var(--theme-lp-surface);
    --lp-ink: var(--ol-text);
    --lp-ink2: var(--ol-text2);
    --lp-muted: var(--ol-text2);
    --lp-faint: var(--ol-text3);
    --lp-line: var(--ol-border);
    --lp-line2: var(--ol-border2);
    --lp-shadow: 0 1px 2px rgba(56, 58, 66, 0.06);
    --lp-shadow-lg: 0 24px 64px rgba(56, 58, 66, 0.1), 0 8px 24px rgba(56, 58, 66, 0.06);
    --font-lp-hero-dot: 'Doto', ui-monospace, monospace;

    background-color: var(--ol-bg);
    color: var(--lp-ink);
    min-height: 100vh;
    font-family: var(--font-lp-sans);
    -webkit-font-smoothing: antialiased;
  }

  .lp-chevron {
    opacity: 0.55;
  }

  /* ── Hero ── */
  .lp-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1rem 0;
  }

  .lp-hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 70rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .lp-hero-heading {
    margin: 0;
    width: max-content;
    max-width: 100%;
    margin-inline: auto;
    font-family: var(--font-lp-hero-dot);
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 700;
    font-variation-settings: 'ROND' 100;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--ol-text);
    -webkit-font-smoothing: auto;
    -moz-osx-font-smoothing: auto;
    text-shadow: 0 0.06em 0 color-mix(in oklab, var(--ol-text) 24%, transparent);
  }

  .lp-hero-sub {
    margin: clamp(0.85rem, 0.5rem + 1.2vw, 1.125rem) 0 0;
    width: 100%;
    max-width: 100%;
    padding: 0;
    box-sizing: border-box;
    font-size: clamp(0.8125rem, 0.42rem + 1.45vw, 1rem);
    font-weight: 400;
    letter-spacing: -0.012em;
    line-height: 1.55;
    color: var(--lp-muted);
  }

  .lp-hero-sub-line {
    display: block;
  }

  .lp-hero-sub-line--mobile {
    display: none;
  }

  .lp-hero-sub-line + .lp-hero-sub-line {
    margin-top: clamp(0.22rem, 0.12rem + 0.35vw, 0.3rem);
  }

  .lp-yc-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin: 1.25rem 0 0;
    padding: 0;
    border: none;
    background: none;
    box-shadow: none;
    color: var(--ol-text2);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.35;
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .lp-yc-badge:hover {
    color: var(--ol-text);
  }

  .lp-yc-badge:focus-visible {
    outline: 2px solid rgba(64, 120, 242, 0.3);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .lp-gh-badge {
