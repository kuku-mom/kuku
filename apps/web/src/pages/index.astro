  .lp-cta-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 2.75rem;
    padding: 0 1.25rem;
    border: 1px solid var(--ol-border);
    border-radius: 999px;
    color: var(--ol-text);
    background: var(--ol-bg);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      border-color 0.15s,
      background 0.15s,
      box-shadow 0.15s;
    box-shadow: var(--lp-shadow);
  }

  .lp-cta-outline:hover {
    border-color: var(--ol-border2);
    background: var(--lp-surface);
  }

  .lp-cta-filled {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 2.75rem;
    padding: 0 1.25rem;
    border-radius: 999px;
    background: var(--ol-text);
    color: var(--ol-on-ink);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: var(--lp-shadow);
    transition: background 0.15s;
  }

  .lp-cta-filled:hover {
    background: var(--ol-ink-hover);
  }

  .lp-hero-download {
    position: relative;
    z-index: 1;
    display: inline-block;
    list-style: none;
  }

  .lp-hero-download[open] {
    z-index: 30;
  }

  .lp-hero-download summary.lp-cta-filled--download {
    list-style: none;
    cursor: pointer;
  }

  .lp-hero-download summary.lp-cta-filled--download::-webkit-details-marker {
    display: none;
  }

  .lp-hero-download summary.lp-cta-filled--download:focus-visible {
    outline: 2px solid rgba(64, 120, 242, 0.45);
    outline-offset: 3px;
  }

  .lp-chevron--hero-dl {
    opacity: 0.55;
    flex-shrink: 0;
    transition:
      transform 0.22s ease,
      opacity 0.2s ease;
  }

  .lp-hero-download[open] .lp-chevron--hero-dl {
    transform: rotate(180deg);
    opacity: 0.82;
  }

  .lp-hero-download[open] > .lp-cta-filled {
    background: var(--ol-ink-hover);
  }

  /* Hero download dropdown (panel styles live here; nav has its own copy in LandingNav) */
  .lp-download-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.375rem);
    z-index: 50;
    min-width: 12.5rem;
