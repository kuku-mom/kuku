  .lp-features-alt .lp-features-heading em {
    background-image: linear-gradient(90deg, #7c4dff 0%, #e8912d 100%);
  }

  /* Feature cards — split copy / viz (One Light) */
  .lp-feat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: start;
  }

  .lp-feat-grid-split {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: start;
  }

  .lp-feat-grid-split > .lp-feat-card-tall {
    min-height: 100%;
  }

  .lp-feat-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  .lp-feat-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    background: var(--lp-surface);
    border: 1px solid var(--ol-border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--lp-shadow);
    min-height: 13.5rem;
    transition:
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .lp-feat-card:hover {
    border-color: var(--ol-border2);
    box-shadow:
      0 2px 8px rgba(56, 58, 66, 0.07),
      0 0 0 1px var(--ol-accent-dim);
  }

  .lp-feat-copy {
    padding: 1.625rem 1.5rem;
    border-right: 1px solid var(--ol-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
  }

  .lp-feat-ic {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ol-border);
    border-radius: 0.5rem;
    color: var(--ol-text2);
    background: var(--ol-bg);
    flex-shrink: 0;
  }

  .lp-feat-copy h3 {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--ol-text);
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .lp-feat-copy p {
    margin: 0;
    color: var(--ol-text2);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .lp-feat-viz {
    background: var(--ol-bg);
    padding: 1.25rem 1.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }

  .lp-fv {
    width: 100%;
    max-width: 17rem;
  }

  .lp-fv-mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.6875rem;
  }

  .lp-fv-faint {
    color: var(--ol-text3);
  }

  .lp-fv-caption {
    margin: 0.5rem 0 0;
    font-size: 0.6875rem;
    color: var(--ol-text3);
    text-align: center;
  }

  /* viz: instant search */
  .lp-fv-search-bar {
    position: relative;
    padding: 0.45rem 0.65rem;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    font-size: 0.75rem;
    color: var(--ol-text3);
    margin-bottom: 0.65rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem 0.45rem;
  }

  .lp-fv-search-hit {
    padding: 0.65rem;
    border-radius: 0.375rem;
    background: var(--lp-surface);
    border: 1px solid var(--ol-border);
  }

  .lp-fv-search-hit .lp-fv-snippet {
    margin: 0.35rem 0 0;
    font-size: 0.75rem;
    line-height: 1.45;
    color: var(--ol-text2);
  }

  .lp-fv-search-hit mark {
    background: var(--ol-accent-dim);
    color: var(--ol-accent);
    padding: 0 0.15em;
    border-radius: 0.125rem;
    font-weight: 500;
  }

  /* viz: sessions */
  .lp-fv-sessions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lp-fv-pill {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    font-size: 0.6875rem;
    color: var(--ol-text2);
  }

  .lp-fv-pill-past {
    opacity: 0.85;
  }

  .lp-fv-pill-now {
    border-color: rgba(80, 161, 79, 0.35);
    background: rgba(80, 161, 79, 0.08);
  }

  .lp-fv-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ol-text3);
    flex-shrink: 0;
  }

  .lp-fv-dot-on {
    background: var(--ol-success, #50a14f);
  }

  .lp-fv-sessions .lp-fv-caption {
    text-align: left;
    margin-top: 0.25rem;
  }

  /* viz: follow-up chips */
  .lp-fv-prompts {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .lp-fv-chip {
    padding: 0.45rem 0.55rem;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    font-size: 0.6875rem;
    color: var(--ol-text);
    line-height: 1.35;
  }

  .lp-fv-chip-2 {
    border-color: rgba(64, 120, 242, 0.25);
    background: var(--ol-accent-dim);
  }

  .lp-fv-chip-dim {
    color: var(--ol-text3);
    border-style: dashed;
  }

  /* viz: graph */
  .lp-fv-graph {
    text-align: center;
  }

  .lp-feat-viz--graph .lp-fv {
    max-width: 27.5rem;
  }

  .lp-fv-graph-svg {
    width: 100%;
    max-width: 25.5rem;
    height: auto;
    color: var(--ol-text2);
  }

  .lp-g-bg {
    pointer-events: none;
  }

  .lp-g-lbl {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 6.75px;
    font-weight: 500;
    fill: var(--ol-text3);
    letter-spacing: 0.01em;
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  .lp-g-lbl--hub {
    font-size: 6.25px;
    font-weight: 700;
    fill: var(--theme-ol-on-ink);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .lp-g-lbl--hub-sec {
    font-size: 5.6px;
    font-weight: 700;
    fill: var(--theme-ol-on-ink);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* viz: markdown editor chrome */
  .lp-fv-md-editor {
    padding: 0;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    overflow: hidden;
  }

  .lp-fv-md-titlebar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.65rem;
    border-bottom: 1px solid var(--ol-border);
    background: var(--ol-bg2);
    font-size: 0.6875rem;
    color: var(--ol-text2);
  }

  .lp-fv-md-titlebar-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ol-accent);
    opacity: 0.85;
    flex-shrink: 0;
  }

  .lp-fv-md-filename {
    flex: 1;
    min-width: 0;
    font-weight: 600;
    color: var(--ol-text);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.6875rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lp-fv-md-titlebar-hint {
    flex-shrink: 0;
    font-size: 0.625rem;
    color: var(--ol-text3);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .lp-fv-md-pane {
    padding: 0.45rem 0.4rem 0.55rem 0.3rem;
    /* Reserve peak height (slash + AI code + rows) so the card does not jump during the demo */
    min-height: 21.5rem;
  }

  .lp-md-col {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .lp-md-row {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    min-height: 1.45em;
    margin: 0.04rem 0;
    padding: 0.14rem 0.4rem 0.14rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--ol-text);
    transition: background 0.2s ease;
  }

  .lp-md-row--active {
    background: var(--ol-sel);
  }

  .lp-md-gutter {
    width: 1rem;
    flex-shrink: 0;
    text-align: right;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.625rem;
    color: var(--ol-text3);
    line-height: 1.5;
    user-select: none;
  }

  .lp-md-line-wrap {
    flex: 1;
    min-width: 0;
  }

  .lp-md-caret {
    display: inline-block;
    width: 1.5px;
    height: 0.88em;
    background: var(--ol-accent);
    margin-left: 1px;
    vertical-align: -0.06em;
    visibility: hidden;
    animation: lp-md-caret-blink 1s step-end infinite;
  }

  .lp-md-caret.lp-md-caret--on {
    visibility: visible;
  }

  @keyframes lp-md-caret-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .lp-md-row--pending {
    opacity: 0;
    transform: translateY(5px);
    pointer-events: none;
    transition:
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #lp-demo-md.lp-md-rest-visible .lp-md-row--pending {
    opacity: 1;
    transform: translateY(0);
  }

  .lp-md-row--deferred {
    max-height: 0;
    opacity: 0;
    margin: 0;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
    pointer-events: none;
    transition:
      max-height 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.32s ease,
      margin 0.32s ease,
      padding 0.32s ease;
  }

  #lp-demo-md.lp-md-show-line2 .lp-md-row--deferred {
    max-height: 22rem;
    opacity: 1;
    margin: 0.04rem 0;
    padding: 0.14rem 0.4rem 0.14rem 0.25rem;
    pointer-events: auto;
  }

  .lp-md-slash {
    position: absolute;
    left: 0;
    top: 100%;
    margin-top: 0.2rem;
    z-index: 2;
    min-width: 11.5rem;
    max-width: 100%;
    padding: 0.35rem 0;
    border-radius: 0.5rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    box-shadow:
      0 4px 18px rgba(56, 58, 66, 0.1),
      0 0 0 1px rgba(64, 120, 242, 0.06);
    opacity: 0;
    transform: translateY(-4px) scale(0.98);
    pointer-events: none;
    overflow: visible;
    transition:
      opacity 0.26s ease,
      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lp-md-slash::before {
    content: '';
    position: absolute;
    left: 1.15rem;
    top: -5px;
    width: 9px;
    height: 9px;
    background: var(--lp-surface);
    border-left: 1px solid var(--ol-border);
    border-top: 1px solid var(--ol-border);
    transform: rotate(45deg);
    z-index: 0;
    pointer-events: none;
  }

  .lp-md-slash-title,
  .lp-md-slash-list {
    position: relative;
    z-index: 1;
  }

  #lp-demo-md.lp-md-slash-open .lp-md-slash {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  #lp-demo-md.lp-md-code-live .lp-md-slash {
    opacity: 0;
    transform: translateY(-6px) scale(0.96);
    pointer-events: none;
  }

  .lp-md-ai-code {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(-4px);
    transition:
      max-height 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.32s ease,
      transform 0.36s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #lp-demo-md.lp-md-code-live .lp-md-ai-code {
    max-height: 10rem;
    opacity: 1;
    transform: translateY(0);
  }

  .lp-md-ai-code-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0.35rem 0 0.3rem;
    min-height: 1rem;
  }

  .lp-md-ai-badge {
    font-size: 0.5625rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.1rem 0.32rem;
    border-radius: 0.28rem;
    background: var(--ol-accent-dim);
    color: var(--ol-accent);
    border: 1px solid rgba(64, 120, 242, 0.22);
  }

  .lp-md-ai-file {
    font-size: 0.625rem;
    font-weight: 650;
    color: var(--ol-text2);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .lp-md-ai-status {
    margin-left: auto;
    font-size: 0.5625rem;
    color: var(--ol-text3);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .lp-md-pre {
    margin: 0;
    padding: 0.42rem 0.48rem;
    border-radius: 0.42rem;
    border: 1px solid var(--ol-border);
    background: color-mix(in oklab, var(--ol-bg2) 82%, #0d1117);
  }

  .lp-md-code-wrap {
    display: block;
    margin: 0;
    padding: 0;
    font-size: 0.625rem;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--ol-text);
  }

  .lp-md-caret--code {
    display: inline-block;
    width: 1.5px;
    height: 0.88em;
    margin-left: 1px;
    vertical-align: -0.08em;
    background: var(--ol-accent);
    border-radius: 1px;
    opacity: 0;
    animation: none;
  }

  .lp-md-caret--code.lp-md-caret--on {
    opacity: 1;
    animation: lp-md-caret-blink 1s step-end infinite;
  }

  .lp-md-syn-kw {
    color: color-mix(in oklab, #a626a4 75%, var(--ol-text));
    font-weight: 600;
  }

  .lp-md-syn-fn {
    color: color-mix(in oklab, #4078f2 85%, var(--ol-text));
  }

  .lp-md-syn-str {
    color: color-mix(in oklab, #50a14f 80%, var(--ol-text));
  }

  .lp-md-syn-key {
    color: color-mix(in oklab, #986801 85%, var(--ol-text));
  }

  .lp-md-slash-title {
    padding: 0.15rem 0.65rem 0.35rem;
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--ol-text3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lp-md-slash-list {
    padding: 0 0.3rem 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .lp-md-slash-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.32rem 0.45rem;
    border-radius: 0.3rem;
    font-size: 0.6875rem;
    color: var(--ol-text);
    transition: background 0.12s ease;
  }

  .lp-md-slash-item--act {
    background: var(--ol-sel);
    outline: 1px solid rgba(64, 120, 242, 0.22);
  }

  .lp-md-slash-ic {
    width: 1.35rem;
    height: 1.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.2rem;
    background: var(--ol-bg2);
    font-size: 0.58rem;
    font-weight: 700;
    color: var(--ol-text2);
    flex-shrink: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .lp-md-slash-ic--todo {
    font-size: 0.75rem;
    font-weight: 400;
  }

  .lp-md-slash-txt {
    flex: 1;
    min-width: 0;
  }

  .lp-md-slash-hint {
    margin-left: auto;
    font-size: 0.625rem;
    color: var(--ol-text3);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .lp-md-slash-ic--code {
    font-size: 0.56rem;
    letter-spacing: -0.05em;
  }

  .lp-fv-wl {
    color: var(--ol-accent);
    font-weight: 500;
    background: var(--ol-accent-dim);
    padding: 0 0.2em;
    border-radius: 0.125rem;
  }

  .lp-fv-md-bold {
    font-weight: 600;
  }

  /* viz: agent terminal */
  .lp-fv-agent {
    text-align: left;
    padding: 0;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 14.5rem;
  }

  .lp-ai-cap {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.6rem;
    background: var(--ol-bg2);
    border-bottom: 1px solid var(--ol-border);
    font-size: 0.6875rem;
    color: var(--ol-text2);
  }

  .lp-ai-cap-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ol-success, #50a14f);
    box-shadow: 0 0 0 2px rgba(80, 161, 79, 0.2);
    flex-shrink: 0;
  }

  .lp-ai-cap-title {
    font-weight: 600;
    color: var(--ol-text);
  }

  .lp-ai-cap-sub {
    margin-left: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.625rem;
    color: var(--ol-text3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lp-ai-stream {
    padding: 0.5rem 0.6rem 0.55rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    min-height: 10.25rem;
  }

  .lp-ai-prompt {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.5rem;
    font-size: 0.6875rem;
    line-height: 1.45;
    color: var(--ol-text);
  }

  .lp-ai-prompt-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--ol-text3);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .lp-ai-prompt-inner {
    flex: 1;
    min-width: 0;
    color: var(--ol-text2);
  }

  .lp-ai-caret {
    display: inline-block;
    width: 1.5px;
    height: 0.85em;
    background: var(--ol-accent);
    margin-left: 1px;
    vertical-align: -0.05em;
    animation: lp-md-caret-blink 1s step-end infinite;
  }

  .lp-ai-caret.lp-ai-caret--off {
    visibility: hidden;
    animation: none;
  }

  .lp-ai-step {
    font-size: 0.6875rem;
    line-height: 1.45;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    opacity: 0;
    transform: translateY(5px);
    max-height: 0;
    overflow: hidden;
    pointer-events: none;
    transition:
      opacity 0.38s ease,
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      max-height 0.45s ease;
  }

  .lp-ai-step.lp-ai-step--in {
    opacity: 1;
    transform: translateY(0);
    max-height: 4rem;
    pointer-events: auto;
  }

  .lp-ai-step--hit {
    color: var(--ol-text2);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.65rem;
  }

  .lp-ai-hit-ic {
    color: var(--ol-success, #50a14f);
    font-weight: 600;
  }

  .lp-ai-latency {
    color: var(--ol-text3);
  }

  .lp-ai-step--meta {
    color: var(--ol-text3);
    font-size: 0.65rem;
  }

  .lp-ai-step--idle {
    color: var(--ol-text3);
    font-size: 0.65rem;
    align-items: center;
    gap: 0.4rem;
  }

  .lp-ai-idle-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ol-text3);
    opacity: 0.65;
  }

  .lp-ai-spinner {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 1.5px solid var(--ol-accent-dim);
    border-top-color: var(--ol-accent);
    flex-shrink: 0;
    animation: lp-ai-spin 0.65s linear infinite;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .lp-ai-step.lp-ai-step--in .lp-ai-spinner {
    opacity: 1;
  }

  .lp-ai-step.lp-ai-step--spin-done .lp-ai-spinner {
    opacity: 0;
    animation: none;
  }

  @keyframes lp-ai-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .lp-fv-cmd {
    color: var(--ol-accent);
    font-weight: 600;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .lp-fv-cmd-ok {
    color: var(--ol-success, #50a14f);
  }

  .lp-fv-arg {
    color: var(--ol-text2);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  /* viz: local / offline */
  .lp-fv-local {
    text-align: center;
  }

  .lp-fv-local-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ol-text);
  }

  .lp-fv-local-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ol-success, #50a14f);
    box-shadow: 0 0 0 2px rgba(80, 161, 79, 0.2);
  }

  /* ── Feature viz demos (motion + interaction) ── */
  .lp-fv-search-placeholder {
    transition: opacity 0.2s ease;
  }

  .lp-fv-search-placeholder.lp-fv-search-ph-hide {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    opacity: 0;
  }

  .lp-fv-search-typed {
    color: var(--ol-text);
    font-size: 0.75rem;
    min-height: 1em;
  }

  .lp-fv-caret {
    display: inline-block;
    width: 1.5px;
    height: 0.85em;
    background: var(--ol-accent);
    margin-left: 1px;
    vertical-align: -0.05em;
    animation: lp-caret-blink 1s step-end infinite;
  }

  @keyframes lp-caret-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .lp-fv-search-hit {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.4s ease,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lp-fv-search-hit.lp-fv-search-hit--show {
    opacity: 1;
    transform: translateY(0);
  }

  .lp-fv-sess-connector {
    width: 1px;
    margin: -0.15rem 0 -0.15rem 0.85rem;
    height: 0.65rem;
    background: linear-gradient(to bottom, var(--ol-border), var(--ol-border2));
    border-radius: 1px;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  #lp-demo-sessions.lp-sess-anim .lp-fv-sess-connector {
    opacity: 0.85;
  }

  @keyframes lp-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(80, 161, 79, 0);
    }
    50% {
      box-shadow: 0 0 0 3px rgba(80, 161, 79, 0.18);
    }
  }

  .lp-fv-pill-now.lp-pill-pulse {
    animation: lp-pill-glow 2s ease-in-out infinite;
  }

  .lp-fv-caption--sessions {
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
  }

  #lp-demo-sessions.lp-sess-anim .lp-fv-caption--sessions {
    opacity: 1;
    transform: translateY(0);
  }

  #lp-demo-sessions:not(.lp-sess-anim) .lp-fv-caption--sessions {
    opacity: 0.65;
    transform: translateY(2px);
  }

  .lp-fv-chip-btn {
    display: block;
    width: 100%;
    margin: 0;
    cursor: pointer;
    text-align: left;
    font: inherit;
    line-height: inherit;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.18s ease,
      box-shadow 0.2s ease;
  }

  .lp-fv-chip-btn:hover {
    border-color: var(--ol-border2);
  }

  .lp-fv-chip-btn:active {
    transform: scale(0.99);
  }

  .lp-fv-chip-btn.lp-chip-active {
    border-color: rgba(64, 120, 242, 0.55);
    box-shadow: 0 0 0 2px rgba(64, 120, 242, 0.12);
    background: var(--ol-accent-dim);
  }

  .lp-fv-chip-dim.lp-fv-chip-btn.lp-chip-active {
    color: var(--ol-text2);
    border-style: solid;
  }

  .lp-fv-graph-svg line.lp-g-edge {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    transition: stroke-dashoffset 0.05s linear;
  }

  #lp-demo-graph.lp-graph-live .lp-fv-graph-svg line.lp-g-edge {
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.95s cubic-bezier(0.45, 0, 0.2, 1);
  }

  @keyframes lp-hub-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }
    50% {
      transform: scale(1.05);
      opacity: 1;
    }
  }

  @keyframes lp-hub-pulse-sec {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.52;
    }
    50% {
      transform: scale(1.07);
      opacity: 0.68;
    }
  }

  @keyframes lp-node-pop {
    0% {
      transform: scale(0.88);
      opacity: 0.32;
    }
    100% {
      transform: scale(1);
      opacity: 0.62;
    }
  }

  #lp-demo-graph.lp-graph-live .lp-g-hub--main {
    transform-origin: 182px 92px;
    transform-box: fill-box;
    animation: lp-hub-pulse 2.6s ease-in-out infinite;
  }

  #lp-demo-graph.lp-graph-live .lp-g-hub--sec {
    transform-origin: 38px 94px;
    transform-box: fill-box;
    animation: lp-hub-pulse-sec 3.1s ease-in-out infinite;
  }

  #lp-demo-graph.lp-graph-live .lp-g-hub--ter {
    transform-origin: 308px 56px;
    transform-box: fill-box;
    animation: lp-hub-pulse-sec 3.4s ease-in-out infinite 0.2s;
  }

  #lp-demo-graph.lp-graph-live .lp-g-hub--mini {
    transform-origin: 118px 34px;
    transform-box: fill-box;
    animation: lp-hub-pulse-sec 2.9s ease-in-out infinite 0.35s;
  }

  #lp-demo-graph.lp-graph-live .lp-g-hub--mini-r {
    transform-origin: 268px 138px;
    animation: lp-hub-pulse-sec 3s ease-in-out infinite 0.45s;
  }

  #lp-demo-graph.lp-graph-live .lp-g-node {
    transform-box: fill-box;
    animation: lp-node-pop 0.52s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0.32;
  }

  #lp-demo-graph.lp-graph-live .lp-g-lbl {
    opacity: 1;
  }

  .lp-fv-task-line {
    transition: color 0.25s ease;
  }

  .lp-fv-task-line.lp-task-checked {
    color: var(--ol-success, #50a14f);
  }

  .lp-fv-task-box {
    display: inline-block;
    min-width: 1.65em;
  }

  @keyframes lp-local-dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 2px rgba(80, 161, 79, 0.2);
    }
    50% {
      box-shadow: 0 0 0 5px rgba(80, 161, 79, 0.12);
    }
  }

  #lp-demo-local.lp-local-live .lp-fv-local-dot {
    animation: lp-local-dot-pulse 2.2s ease-in-out infinite;
  }

  .lp-fv-local-caption {
    transition: opacity 0.45s ease;
  }

  #lp-demo-local.lp-local-live .lp-fv-local-caption {
    opacity: 1;
  }

  #lp-demo-local:not(.lp-local-live) .lp-fv-local-caption {
    opacity: 0.55;
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-fv-caret {
      animation: none;
      opacity: 0.55;
    }

    .lp-fv-search-hit {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .lp-fv-sess-connector {
      transition: none;
      height: 0.65rem;
      opacity: 0.85;
    }

    #lp-demo-sessions:not(.lp-sess-anim) .lp-fv-caption--sessions {
      opacity: 1;
      transform: none;
    }

    .lp-fv-pill-now.lp-pill-pulse {
      animation: none;
    }

    .lp-fv-graph-svg .lp-g-edge {
      stroke-dashoffset: 0;
      transition: none;
    }

    #lp-demo-graph.lp-graph-live .lp-g-hub--main,
    #lp-demo-graph.lp-graph-live .lp-g-hub--sec,
    #lp-demo-graph.lp-graph-live .lp-g-hub--ter,
    #lp-demo-graph.lp-graph-live .lp-g-hub--mini,
    #lp-demo-graph.lp-graph-live .lp-g-hub--mini-r,
    #lp-demo-graph.lp-graph-live .lp-g-node {
      animation: none;
    }

    #lp-demo-graph.lp-graph-live .lp-g-node {
      opacity: 0.55;
    }

    #lp-demo-local.lp-local-live .lp-fv-local-dot {
      animation: none;
    }

    .lp-g-lbl {
      opacity: 1;
      transition: none;
    }

    .lp-md-row--pending {
      opacity: 1;
      transform: none;
      transition: none;
      pointer-events: auto;
    }

    .lp-md-row--deferred {
      max-height: none;
      opacity: 1;
      margin: 0.04rem 0;
      padding: 0.14rem 0.4rem 0.14rem 0.25rem;
      pointer-events: auto;
      transition: none;
    }

    .lp-md-caret {
      animation: none;
    }

    .lp-ai-step {
      opacity: 1;
      transform: none;
      max-height: none;
      overflow: visible;
      pointer-events: auto;
      transition: none;
    }

    .lp-ai-spinner {
      animation: none;
      opacity: 0;
    }

    .lp-ai-caret {
      animation: none;
    }
  }

  /* ── CTA Banner (aligned with footer: left rail, soft rule) ── */
  .lp-cta-banner {
    padding: 3.5rem 2rem 3.25rem;
    text-align: left;
    border-top: 1px solid color-mix(in oklab, var(--ol-border) 38%, transparent);
    background: var(--ol-bg);
  }

  .lp-cta-banner-inner {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .lp-cta-heading {
    margin: 0;
    max-width: 22rem;
    font-size: clamp(1.65rem, 3.8vw, 2.35rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    color: var(--lp-ink);
  }

  .lp-cta-sub {
    margin: 0.85rem 0 0;
    max-width: 28rem;
    color: var(--lp-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .lp-cta-banner-actions {
    margin-top: 1.5rem;
    justify-content: flex-start;
  }

  /* ── Responsive ── */
  @media (max-width: 48rem) {
    .lp-hero {
      padding: 3.25rem 0.75rem 0;
    }

    .lp-hero-sub {
      max-width: 20rem;
      font-size: 0.875rem;
      line-height: 1.55;
    }

    .lp-hero-sub .lp-hero-sub-line--desktop {
      display: none !important;
    }

    .lp-hero-sub .lp-hero-sub-line--mobile {
      display: block !important;
    }

    .lp-screenshot-wrap {
      margin-top: 2rem;
      padding: 0 0.35rem;
    }

    .lp-screenshot-body {
      --lp-mockup-scale: 0.62;
      height: clamp(22rem, 78vw, 30rem);
    }

    .lp-features {
      padding: 3rem 1rem;
    }

    .lp-feat-grid {
      grid-template-columns: 1fr;
    }

    .lp-feat-grid-split {
      grid-template-columns: 1fr;
    }

    .lp-feat-card {
      grid-template-columns: 1fr;
