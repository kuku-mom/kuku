  @media (prefers-reduced-motion: reduce) {
    .lp-fv-caret {
      animation: none;
      opacity: 0.55;
    }

    .lp-fv-search-hit {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .lp-fv-sess-connector {
      transition: none;
      height: 0.65rem;
      opacity: 0.85;
    }

    #lp-demo-sessions:not(.lp-sess-anim) .lp-fv-caption--sessions {
      opacity: 1;
      transform: none;
    }

    .lp-fv-pill-now.lp-pill-pulse {
      animation: none;
    }

    .lp-fv-graph-svg .lp-g-edge {
      stroke-dashoffset: 0;
      transition: none;
    }

    #lp-demo-graph.lp-graph-live .lp-g-hub--main,
    #lp-demo-graph.lp-graph-live .lp-g-hub--sec,
    #lp-demo-graph.lp-graph-live .lp-g-hub--ter,
    #lp-demo-graph.lp-graph-live .lp-g-hub--mini,
    #lp-demo-graph.lp-graph-live .lp-g-hub--mini-r,
    #lp-demo-graph.lp-graph-live .lp-g-node {
      animation: none;
    }

    #lp-demo-graph.lp-graph-live .lp-g-node {
      opacity: 0.55;
    }

    #lp-demo-local.lp-local-live .lp-fv-local-dot {
      animation: none;
    }

    #lp-demo-brain.lp-brain-live .lp-brain-packet {
      animation: none;
      left: 100%;
      opacity: 1;
    }

    .lp-brain-mini-row {
      opacity: 1;
      transform: none;
    }

    .lp-brain-chip {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .lp-g-lbl {
      opacity: 1;
      transition: none;
    }

    .lp-md-row--pending {
      opacity: 1;
      transform: none;
      transition: none;
      pointer-events: auto;
    }

    .lp-md-row--deferred {
      max-height: none;
      opacity: 1;
      margin: 0.04rem 0;
      padding: 0.14rem 0.4rem 0.14rem 0.25rem;
      pointer-events: auto;
      transition: none;
    }

    .lp-md-caret {
      animation: none;
    }

    .lp-ai-step {
      opacity: 1;
      transform: none;
      max-height: none;
      overflow: visible;
      pointer-events: auto;
      transition: none;
    }

    .lp-ai-spinner {
      animation: none;
      opacity: 0;
    }

    .lp-ai-caret {
      animation: none;
    }
  }

  /* ── CTA Banner (aligned with footer: left rail, soft rule) ── */
  .lp-cta-banner {
    padding: 3.5rem 2rem 3.25rem;
    text-align: left;
    border-top: 1px solid color-mix(in oklab, var(--ol-border) 38%, transparent);
