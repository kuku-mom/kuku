<style>
  /* ── One Light (same tokens as app_mockup.astro) ── */
  .lp-root {
    --ol-bg: var(--theme-ol-bg);
    --ol-bg2: var(--theme-ol-bg2);
    --ol-bg3: var(--theme-ol-bg3);
    --ol-border: var(--theme-ol-border);
    --ol-border2: var(--theme-ol-border2);
    --ol-text: var(--theme-ol-text);
    --ol-text2: var(--theme-ol-text2);
    --ol-text3: var(--theme-ol-text3);
    --ol-accent: var(--theme-ol-accent);
    --ol-accent-dim: var(--theme-ol-accent-dim);
    --ol-sel: var(--theme-ol-sel);
    --ol-inact: var(--theme-ol-inact);
    --ol-success: var(--theme-ol-success);
    --ol-error: var(--theme-ol-error);
    --ol-on-ink: var(--theme-ol-on-ink);
    --ol-ink-hover: var(--theme-ol-ink-hover);

    --lp-bg0: var(--ol-bg);
    --lp-bg1: var(--ol-bg2);
    --lp-surface: var(--theme-lp-surface);
    --lp-ink: var(--ol-text);
    --lp-ink2: var(--ol-text2);
    --lp-muted: var(--ol-text2);
    --lp-faint: var(--ol-text3);
    --lp-line: var(--ol-border);
    --lp-line2: var(--ol-border2);
    --lp-shadow: 0 1px 2px rgba(56, 58, 66, 0.06);
    --lp-shadow-lg: 0 24px 64px rgba(56, 58, 66, 0.1), 0 8px 24px rgba(56, 58, 66, 0.06);
    --font-lp-hero-dot: 'Doto', ui-monospace, monospace;

    background-color: var(--ol-bg);
    color: var(--lp-ink);
    min-height: 100vh;
    font-family: var(--font-lp-sans);
    -webkit-font-smoothing: antialiased;
  }

  .lp-chevron {
    opacity: 0.55;
  }

  /* ── Hero ── */
  .lp-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1rem 0;
  }

  .lp-hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 70rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .lp-ph-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 clamp(0.85rem, 0.58rem + 0.9vw, 1.2rem);
    padding: 0.42rem 0.72rem 0.42rem 0.5rem;
    border: 1px solid color-mix(in oklab, var(--ol-border) 86%, transparent);
    border-radius: 999px;
    background: color-mix(in oklab, var(--ol-bg) 88%, white 12%);
    color: var(--ol-text2);
    box-shadow: 0 1px 2px rgba(56, 58, 66, 0.04);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    text-decoration: none;
    transition:
      border-color 0.18s ease,
      color 0.18s ease,
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .lp-ph-badge:hover {
    border-color: color-mix(in oklab, #da552f 34%, var(--ol-border));
    color: var(--ol-text);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(56, 58, 66, 0.08);
  }

  .lp-ph-badge:focus-visible {
    outline: 2px solid rgba(218, 85, 47, 0.24);
    outline-offset: 3px;
  }

  .lp-ph-mark {
    display: grid;
    place-items: center;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 50%;
    background: #da552f;
    color: #fff;
    font-family: 'Satoshi', var(--font-lp-sans);
    font-size: 0.76rem;
    font-weight: 800;
    line-height: 1;
    text-align: center;
    flex-shrink: 0;
  }

  .lp-ph-letter {
    display: block;
    transform: translate(0.025em, 0.035em);
  }

  .lp-ph-copy {
    color: inherit;
    white-space: nowrap;
  }

  .lp-ph-arrow {
    width: 0.72rem;
    height: 0.72rem;
    color: inherit;
    opacity: 0.38;
    flex-shrink: 0;
    transition:
      transform 0.2s ease,
      opacity 0.18s ease;
  }

  .lp-ph-badge:hover .lp-ph-arrow {
    transform: translate(1px, -1px);
    opacity: 0.62;
  }

  .lp-hero-heading {
    margin: 0;
    width: max-content;
    max-width: 100%;
    margin-inline: auto;
    font-family: var(--font-lp-hero-dot);
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 700;
    font-variation-settings: 'ROND' 100;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--ol-text);
    -webkit-font-smoothing: auto;
    -moz-osx-font-smoothing: auto;
    text-shadow: 0 0.06em 0 color-mix(in oklab, var(--ol-text) 24%, transparent);
  }

  .lp-hero-sub {
    margin: clamp(0.85rem, 0.5rem + 1.2vw, 1.125rem) 0 0;
    width: 100%;
    max-width: 100%;
    padding: 0;
    box-sizing: border-box;
    font-size: clamp(0.8125rem, 0.42rem + 1.45vw, 1rem);
    font-weight: 400;
    letter-spacing: -0.012em;
    line-height: 1.55;
    color: var(--lp-muted);
  }

  .lp-hero-sub-line {
    display: block;
  }

  .lp-hero-sub-line--mobile {
    display: none;
  }

  .lp-hero-sub-line + .lp-hero-sub-line {
    margin-top: clamp(0.22rem, 0.12rem + 0.35vw, 0.3rem);
  }

  .lp-yc-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin: 1.25rem 0 0;
    padding: 0;
    border: none;
    background: none;
    box-shadow: none;
    color: var(--ol-text2);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.35;
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .lp-yc-badge:hover {
    color: var(--ol-text);
  }

  .lp-yc-badge:focus-visible {
    outline: 2px solid rgba(64, 120, 242, 0.3);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .lp-gh-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    color: inherit;
    opacity: 0.88;
    flex-shrink: 0;
  }

  .lp-gh-badge svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .lp-yc-copy {
    color: inherit;
  }

  .lp-yc-link {
    position: relative;
    display: inline-block;
    color: inherit;
    font-weight: inherit;
    font-size: inherit;
    text-decoration: none;
  }

  .lp-yc-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.08em;
    height: 1px;
    background: color-mix(in oklab, currentColor 82%, transparent);
    transform: scaleX(0);
    transform-origin: left center;
    opacity: 0.8;
    transition:
      transform 0.26s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.22s ease;
  }

  .lp-yc-badge:hover .lp-yc-link::after,
  .lp-yc-badge:focus-visible .lp-yc-link::after {
    transform: scaleX(1);
    opacity: 1;
  }

  .lp-yc-arrow {
    width: 0.8rem;
    height: 0.8rem;
    color: inherit;
    opacity: 0.42;
    margin-left: 0.02rem;
    transition:
      transform 0.2s ease,
      opacity 0.18s ease;
    flex-shrink: 0;
  }

  .lp-yc-badge:hover .lp-yc-arrow {
    transform: translate(2px, -2px);
    opacity: 0.65;
  }

  .lp-hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    overflow: visible;
  }

  .lp-cta-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 2.75rem;
    padding: 0 1.25rem;
    border: 1px solid var(--ol-border);
    border-radius: 999px;
    color: var(--ol-text);
    background: var(--ol-bg);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      border-color 0.15s,
      background 0.15s,
      box-shadow 0.15s;
    box-shadow: var(--lp-shadow);
  }

  .lp-cta-outline:hover {
    border-color: var(--ol-border2);
    background: var(--lp-surface);
  }

  .lp-cta-filled {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 2.75rem;
    padding: 0 1.25rem;
    border-radius: 999px;
    background: var(--ol-text);
    color: var(--ol-on-ink);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: var(--lp-shadow);
    transition: background 0.15s;
  }

  .lp-cta-filled:hover {
    background: var(--ol-ink-hover);
  }

  .lp-hero-download {
    position: relative;
    z-index: 1;
    display: inline-block;
    list-style: none;
  }

  .lp-hero-download[open] {
    z-index: 30;
  }

  .lp-hero-download summary.lp-cta-filled--download {
    list-style: none;
    cursor: pointer;
  }

  .lp-hero-download summary.lp-cta-filled--download::-webkit-details-marker {
    display: none;
  }

  .lp-hero-download summary.lp-cta-filled--download:focus-visible {
    outline: 2px solid rgba(64, 120, 242, 0.45);
    outline-offset: 3px;
  }

  .lp-chevron--hero-dl {
    opacity: 0.55;
    flex-shrink: 0;
    transition:
      transform 0.22s ease,
      opacity 0.2s ease;
  }

  .lp-hero-download[open] .lp-chevron--hero-dl {
    transform: rotate(180deg);
    opacity: 0.82;
  }

  .lp-hero-download[open] > .lp-cta-filled {
    background: var(--ol-ink-hover);
  }

  /* Hero download dropdown (panel styles live here; nav has its own copy in LandingNav) */
  .lp-download-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.375rem);
    z-index: 50;
    min-width: 12.5rem;
    padding: 0.35rem;
    background: var(--lp-surface);
    border: 1px solid color-mix(in oklab, var(--ol-border) 80%, transparent);
    border-radius: 0.5rem;
    box-shadow:
      0 4px 24px rgba(56, 58, 66, 0.08),
      0 1px 3px rgba(56, 58, 66, 0.06);
  }

  .lp-download-panel--hero {
    left: 50%;
    right: auto;
    transform: translateX(-50%);
  }

  .lp-download-row {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--ol-text2);
  }

  a.lp-download-row--link {
    color: var(--ol-text);
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.18s ease,
      color 0.18s ease;
  }

  a.lp-download-row--link:hover {
    background: color-mix(in oklab, var(--ol-text) 5.5%, transparent);
    color: var(--ol-text);
  }

  .lp-download-row--soon {
    cursor: default;
    color: var(--ol-text2);
  }

  .lp-download-soon {
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--lp-faint);
  }

  /* ── App Screenshot ── */
  .lp-screenshot-wrap {
    position: relative;
    z-index: 0;
    width: min(100%, 96rem);
    margin: clamp(2.25rem, 1.25rem + 2.5vw, 3.5rem) auto 0;
    padding: 0 clamp(0.75rem, 0.35rem + 1.5vw, 2rem);
    /* Hero is center-aligned; app preview text must stay left-aligned like the real app */
    text-align: left;
  }

  .lp-screenshot-chrome {
    border: 1px solid var(--ol-border);
    border-radius: clamp(0.5rem, 0.35rem + 0.65vw, 0.875rem);
    overflow: hidden;
    background: var(--lp-surface);
    box-shadow: var(--lp-shadow-lg);
  }

  /* ── Generic image placeholder ── */
  .lp-img-placeholder {
    background: repeating-linear-gradient(
      -45deg,
      rgba(56, 58, 66, 0.04) 0,
      rgba(56, 58, 66, 0.04) 1px,
      transparent 0,
      transparent 50%
    );
    background-size: 8px 8px;
    background-color: var(--ol-bg2);
    border: 1px dashed var(--ol-border);
  }

  /* screenshot body: sized to contain the app mockup; scales down on narrow viewports */
  .lp-screenshot-body {
    /* Uniform scale keeps fonts, panels, and chrome proportional (avoids re-tuning mockup CSS). */
    --lp-mockup-scale: 0.9;
    height: clamp(20rem, 13.25rem + 34vw, 57rem);
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .lp-screenshot-body :global(#am-demo.am-root) {
    flex-shrink: 0;
    width: calc(100% / var(--lp-mockup-scale));
    height: calc(100% / var(--lp-mockup-scale));
    max-width: none;
    transform: scale(var(--lp-mockup-scale));
    transform-origin: top center;
  }

  /* ── Features ── */
  .lp-features {
    margin-top: 7rem;
    padding: 4rem 2rem 5rem;
    background: linear-gradient(180deg, var(--ol-bg2) 0%, var(--ol-bg3) 100%);
    border-top: 1px solid var(--ol-border);
  }

  .lp-features-alt {
    margin-top: 0;
    background: linear-gradient(180deg, var(--ol-bg3) 0%, var(--ol-bg) 100%);
  }

  .lp-features-brain {
    margin-top: 0;
    background: linear-gradient(180deg, var(--ol-bg3) 0%, var(--ol-bg2) 100%);
  }

  .lp-features-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 72rem;
    margin: 0 auto 2.5rem;
    color: var(--lp-faint);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .lp-features-label span:last-child {
    color: var(--ol-text3);
    opacity: 0.85;
  }

  .lp-features-heading {
    max-width: 72rem;
    margin: 0 auto 3rem;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--lp-ink);
  }

  .lp-features-heading em {
    font-family: var(--font-lp-accent-serif);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: transparent;
    background-image: linear-gradient(90deg, #3566d4 0%, #18a38a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .lp-features-alt .lp-features-heading em {
    background-image: linear-gradient(90deg, #7c4dff 0%, #e8912d 100%);
  }

  .lp-features-brain .lp-features-heading em {
    background-image: linear-gradient(90deg, #3566d4 0%, #50a14f 100%);
  }

  .lp-brain-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.42fr);
    gap: 1.25rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: stretch;
  }

  .lp-brain-panel,
  .lp-brain-runtime {
    background: var(--lp-surface);
    border: 1px solid var(--ol-border);
    border-radius: 0.75rem;
    box-shadow: var(--lp-shadow);
  }

  .lp-brain-panel {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    overflow: hidden;
  }

  .lp-brain-copy {
    padding: 1.625rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
  }

  .lp-brain-copy + .lp-brain-copy {
    border-left: 1px solid var(--ol-border);
  }

  .lp-brain-copy h3 {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--ol-text);
  }

  .lp-brain-copy p {
    margin: 0;
    color: var(--ol-text2);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .lp-brain-mini-sync {
    margin-top: auto;
    padding-top: 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .lp-brain-mini-row {
    display: grid;
    grid-template-columns: 0.55rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.45rem;
    padding: 0.42rem 0.5rem;
    border: 1px solid var(--ol-border);
    border-radius: 0.4rem;
    background: var(--ol-bg);
    color: var(--ol-text3);
    opacity: 0.72;
    transform: translateY(4px);
    transition:
      opacity 0.28s ease,
      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.22s ease,
      background 0.22s ease,
      color 0.22s ease;
  }

  .lp-brain-mini-row span {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: currentColor;
  }

  .lp-brain-mini-row strong,
  .lp-brain-mini-row small {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.625rem;
    line-height: 1.35;
  }

  .lp-brain-mini-row strong {
    font-weight: 650;
  }

  .lp-brain-mini-row small {
    color: var(--ol-text3);
  }

  .lp-brain-mini-row.lp-brain-mini-row--on {
    opacity: 1;
    transform: translateY(0);
    border-color: rgba(80, 161, 79, 0.35);
    background: rgba(80, 161, 79, 0.08);
    color: var(--ol-success);
  }

  .lp-brain-mini-wiki {
    position: relative;
    margin-top: auto;
    min-height: 5.9rem;
    border: 1px solid var(--ol-border);
    border-radius: 0.5rem;
    background: var(--ol-bg);
    overflow: hidden;
  }

  .lp-second-brain-mark {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 4.3rem;
    height: 4.3rem;
    color: var(--ol-text2);
    opacity: 0.42;
    transform: translate(-50%, -50%);
    transition:
      color 0.3s ease,
      opacity 0.3s ease,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #lp-demo-second-brain.lp-second-brain-live .lp-second-brain-mark {
    color: var(--ol-accent);
    opacity: 0.72;
    transform: translate(-50%, -50%) scale(1.05);
  }

  .lp-brain-chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    max-width: 8.5rem;
    min-height: 1.35rem;
    padding: 0.18rem 0.4rem;
    border: 1px solid var(--ol-border);
    border-radius: 999px;
    background: var(--lp-surface);
    color: var(--ol-text2);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.6rem;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0;
    transform: translateY(5px);
    transition:
      opacity 0.34s ease,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.24s ease,
      background 0.24s ease;
  }

  .lp-brain-chip--a {
    left: 0.65rem;
    top: 0.55rem;
  }

  .lp-brain-chip--b {
    right: 0.65rem;
    top: 2.15rem;
  }

  .lp-brain-chip--c {
    left: 1.2rem;
    bottom: 0.65rem;
  }

  #lp-demo-second-brain.lp-second-brain-live .lp-brain-chip {
    opacity: 1;
    transform: translateY(0);
    border-color: rgba(64, 120, 242, 0.24);
    background: var(--ol-accent-dim);
  }

  #lp-demo-second-brain.lp-second-brain-live .lp-brain-chip--b {
    transition-delay: 0.16s;
  }

  #lp-demo-second-brain.lp-second-brain-live .lp-brain-chip--c {
    transition-delay: 0.32s;
  }

  .lp-brain-runtime {
    padding: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: hidden;
  }

  .lp-brain-topbar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.55rem;
    border-radius: 0.45rem;
    background: var(--ol-bg2);
    border: 1px solid var(--ol-border);
    color: var(--ol-text2);
    font-size: 0.6875rem;
  }

  .lp-brain-topbar-title {
    font-weight: 650;
    color: var(--ol-text);
  }

  .lp-brain-phase {
    margin-left: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.625rem;
    color: var(--ol-accent);
  }

  .lp-brain-flow {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 3.5rem minmax(0, 1fr);
    align-items: center;
    gap: 0.45rem;
    min-height: 4.75rem;
  }

  .lp-brain-device {
    min-width: 0;
    min-height: 3.8rem;
    padding: 0.7rem 0.55rem;
    border: 1px solid var(--ol-border);
    border-radius: 0.5rem;
    background: var(--ol-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    color: var(--ol-text2);
    font-size: 0.6875rem;
    text-align: center;
  }

  .lp-brain-device-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 0.35rem;
    background: var(--lp-surface);
    border: 1px solid var(--ol-border);
    color: var(--ol-text);
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .lp-brain-pipe {
    position: relative;
    height: 1px;
    background: var(--ol-border2);
    opacity: 0.9;
  }

  .lp-brain-pipe::before,
  .lp-brain-pipe::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 5px;
    height: 5px;
    border-top: 1px solid var(--ol-border2);
    border-right: 1px solid var(--ol-border2);
  }

  .lp-brain-pipe::before {
    left: 0;
    transform: translateY(-50%) rotate(225deg);
  }

  .lp-brain-pipe::after {
    right: 0;
    transform: translateY(-50%) rotate(45deg);
  }

  .lp-brain-packet {
    position: absolute;
    top: 50%;
    left: 0;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--ol-accent);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 3px var(--ol-accent-dim);
    opacity: 0;
  }

  #lp-demo-brain.lp-brain-live .lp-brain-packet {
    opacity: 1;
    animation: lp-brain-packet 2.3s ease-in-out infinite;
  }

  @keyframes lp-brain-packet {
    0%,
    100% {
      left: 0;
    }
    50% {
      left: 100%;
    }
  }

  .lp-brain-steps {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .lp-brain-step {
    display: grid;
    grid-template-columns: 0.55rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.55rem;
    border: 1px solid var(--ol-border);
    border-radius: 0.42rem;
    background: var(--ol-bg);
    color: var(--ol-text3);
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .lp-brain-step span {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: currentColor;
  }

  .lp-brain-step strong,
  .lp-brain-step small {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .lp-brain-step small {
    color: var(--ol-text3);
    font-weight: 500;
  }

  .lp-brain-step.lp-brain-step--active {
    border-color: rgba(64, 120, 242, 0.35);
    background: var(--ol-accent-dim);
    color: var(--ol-accent);
  }

  .lp-inspiration {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.4rem;
    margin: 0.05rem 0 0;
    padding: 0 0.1rem;
    color: var(--ol-text3);
    font-size: 0.625rem;
    line-height: 1.4;
    white-space: nowrap;
  }

  .lp-inspiration-link {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    min-width: 0;
    color: var(--ol-text2);
    text-decoration: none;
    transition:
      color 0.18s ease,
      transform 0.18s ease;
  }

  .lp-inspiration-link:hover {
    transform: translateY(-1px);
    color: var(--ol-text);
  }

  .lp-inspiration-link:focus-visible {
    outline: 2px solid rgba(64, 120, 242, 0.3);
    outline-offset: 3px;
    border-radius: 999px;
  }

  .lp-inspiration-link img {
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(1);
    border: 1px solid var(--ol-border);
    flex-shrink: 0;
  }

  /* Feature cards — split copy / viz (One Light) */
  .lp-feat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: start;
  }

  .lp-feat-grid-split {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: start;
  }

  .lp-feat-grid-split > .lp-feat-card-tall {
    min-height: 100%;
  }

  .lp-feat-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  .lp-feat-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    background: var(--lp-surface);
    border: 1px solid var(--ol-border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--lp-shadow);
    min-height: 13.5rem;
    transition:
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .lp-feat-card:hover {
    border-color: var(--ol-border2);
    box-shadow:
      0 2px 8px rgba(56, 58, 66, 0.07),
      0 0 0 1px var(--ol-accent-dim);
  }

  .lp-feat-copy {
    padding: 1.625rem 1.5rem;
    border-right: 1px solid var(--ol-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
  }

  .lp-feat-ic {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ol-border);
    border-radius: 0.5rem;
    color: var(--ol-text2);
    background: var(--ol-bg);
    flex-shrink: 0;
  }

  .lp-feat-copy h3 {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--ol-text);
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .lp-feat-copy p {
    margin: 0;
    color: var(--ol-text2);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .lp-feat-viz {
    background: var(--ol-bg);
    padding: 1.25rem 1.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }

  .lp-fv {
    width: 100%;
    max-width: 17rem;
  }

  .lp-fv-mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.6875rem;
  }

  .lp-fv-faint {
    color: var(--ol-text3);
  }

  .lp-fv-caption {
    margin: 0.5rem 0 0;
    font-size: 0.6875rem;
    color: var(--ol-text3);
    text-align: center;
  }

  /* viz: instant search */
  .lp-fv-search-bar {
    position: relative;
    padding: 0.45rem 0.65rem;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    font-size: 0.75rem;
    color: var(--ol-text3);
    margin-bottom: 0.65rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem 0.45rem;
  }

  .lp-fv-search-hit {
    padding: 0.65rem;
    border-radius: 0.375rem;
    background: var(--lp-surface);
    border: 1px solid var(--ol-border);
  }

  .lp-fv-search-hit .lp-fv-snippet {
    margin: 0.35rem 0 0;
    font-size: 0.75rem;
    line-height: 1.45;
    color: var(--ol-text2);
  }

  .lp-fv-search-hit mark {
    background: var(--ol-accent-dim);
    color: var(--ol-accent);
    padding: 0 0.15em;
    border-radius: 0.125rem;
    font-weight: 500;
  }

  /* viz: sessions */
  .lp-fv-sessions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lp-fv-pill {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    font-size: 0.6875rem;
    color: var(--ol-text2);
  }

  .lp-fv-pill-past {
    opacity: 0.85;
  }

  .lp-fv-pill-now {
    border-color: rgba(80, 161, 79, 0.35);
    background: rgba(80, 161, 79, 0.08);
  }

  .lp-fv-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ol-text3);
    flex-shrink: 0;
  }

  .lp-fv-dot-on {
    background: var(--ol-success, #50a14f);
  }

  .lp-fv-sessions .lp-fv-caption {
    text-align: left;
    margin-top: 0.25rem;
  }

  /* viz: follow-up chips */
  .lp-fv-prompts {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .lp-fv-chip {
    padding: 0.45rem 0.55rem;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    font-size: 0.6875rem;
    color: var(--ol-text);
    line-height: 1.35;
  }

  .lp-fv-chip-2 {
    border-color: rgba(64, 120, 242, 0.25);
    background: var(--ol-accent-dim);
  }

  .lp-fv-chip-dim {
    color: var(--ol-text3);
    border-style: dashed;
  }

  /* viz: graph */
  .lp-fv-graph {
    text-align: center;
  }

  .lp-feat-viz--graph .lp-fv {
    max-width: 27.5rem;
  }

  .lp-fv-graph-svg {
    width: 100%;
    max-width: 25.5rem;
    height: auto;
    color: var(--ol-text2);
  }

  .lp-g-bg {
    pointer-events: none;
  }

  .lp-g-lbl {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 6.75px;
    font-weight: 500;
    fill: var(--ol-text3);
    letter-spacing: 0.01em;
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  .lp-g-lbl--hub {
    font-size: 6.25px;
    font-weight: 700;
    fill: var(--theme-ol-on-ink);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .lp-g-lbl--hub-sec {
    font-size: 5.6px;
    font-weight: 700;
    fill: var(--theme-ol-on-ink);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* viz: markdown editor chrome */
  .lp-fv-md-editor {
    padding: 0;
    border-radius: 0.375rem;
    border: 1px solid var(--ol-border);
    background: var(--lp-surface);
    overflow: hidden;
  }

  .lp-fv-md-titlebar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.65rem;
    border-bottom: 1px solid var(--ol-border);
    background: var(--ol-bg2);
    font-size: 0.6875rem;
