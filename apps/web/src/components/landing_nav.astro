    const LANG_LABELS = { en: 'English', ko: '한국어', ja: '日本語' };
    const STORAGE_KEY = 'kuku_lang';

    function applyLang(lang) {
      const t = T[lang];
      if (!t) return;

      /* plain text */
      document.querySelectorAll('[data-i18n]').forEach(function (el) {
        const key = el.getAttribute('data-i18n');
        if (t[key] !== undefined) el.textContent = t[key];
      });

      /* html content (headings with <em>, <br>, badges) */
      document.querySelectorAll('[data-i18n-html]').forEach(function (el) {
        const key = el.getAttribute('data-i18n-html');
        if (t[key] !== undefined) el.innerHTML = t[key];
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(function (el) {
        const key = el.getAttribute('data-i18n-placeholder');
        if (t[key] !== undefined) el.setAttribute('placeholder', t[key]);
      });

      /* update the lang button label */
      const label = document.getElementById('lp-lang-label');
      if (label) label.textContent = LANG_LABELS[lang] || lang;

      /* mark active option */
      document.querySelectorAll('[data-lang]').forEach(function (btn) {
        btn.setAttribute(
          'aria-selected',
          btn.getAttribute('data-lang') === lang ? 'true' : 'false',
        );
      });

      /* html[lang] attribute */
      document.documentElement.lang = lang;

      localStorage.setItem(STORAGE_KEY, lang);
    }

    /* ── Init ── */
    function ready(fn) {
      if (document.readyState !== 'loading') fn();
      else document.addEventListener('DOMContentLoaded', fn);
    }

    ready(function () {
      const saved = localStorage.getItem(STORAGE_KEY) || 'en';
      applyLang(saved);
    });

    /* ── Re-apply translations after runtime DOM swaps ──
       AuthNavLink toggles its `data-i18n` key once the login check
       resolves; dispatch this event from there to re-run applyLang so
       the newly-visible key gets localized. */
    window.addEventListener('kuku:lang-refresh', function () {
      const saved = localStorage.getItem(STORAGE_KEY) || 'en';
      applyLang(saved);
    });

    /* ── Language option clicks ── */
    document.addEventListener('click', function (e) {
      if (!(e.target instanceof Element)) return;

      const btn = e.target.closest('[data-lang]');
      if (btn) {
        const lang = btn.getAttribute('data-lang');
        if (T[lang]) {
          applyLang(lang);
          const detailsPanel = btn.closest('details');
          if (detailsPanel) detailsPanel.removeAttribute('open');
        }
        return;
      }

      /* close lang panel on outside click */
      const langMenu = document.getElementById('lp-nav-lang');
      if (langMenu && langMenu.hasAttribute('open') && !langMenu.contains(e.target)) {
        langMenu.removeAttribute('open');
      }
    });
  })();
</script>
