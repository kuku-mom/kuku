---
import AuthNavLink from '@/components/auth_nav_link';
import { resolveDownloadHref } from '@/config/links';
import { LANG_LABELS, MESSAGES, type MessageKey } from '@/i18n';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;

interface NavItem {
  href: string;
  label: string;
  i18n: MessageKey;
}

const nav = [
  { href: '/roadmap', label: 'Roadmap', i18n: 'nav.roadmap' },
  { href: '/pricing', label: 'Pricing', i18n: 'nav.pricing' },
  { href: '/blog', label: 'Blog', i18n: 'nav.blog' },
] as const satisfies readonly NavItem[];

const downloadHashHref = resolveDownloadHref(pathname);

function serializeInlineJson(value: unknown): string {
  return JSON.stringify(value).replaceAll('<', String.raw`\u003c`);
}

const i18nPayloadJson = serializeInlineJson({
  labels: LANG_LABELS,
  messages: MESSAGES,
});
---

<header class="lp-nav">
  <div class="lp-nav-inner">
    <div class="lp-nav-start">
      <a class="lp-brand" href="/" aria-label="kuku home">
        <img class="lp-brand-logo" src="/logo.svg" alt="" width="52" height="52" decoding="async" />
        <span class="lp-brand-tagline-text">kuku.mom</span>
      </a>
    </div>
    <nav class="lp-nav-links" aria-label="Main navigation">
      {
        nav.map(({ href, label, i18n }) => (
          <a href={href} aria-current={pathname === href ? 'page' : undefined} data-i18n={i18n}>
            {label}
          </a>
        ))
      }
    </nav>
    <div class="lp-nav-actions">
      <!-- Language picker -->
      <details class="lp-nav-lang" id="lp-nav-lang">
        <summary class="lp-btn-lang" aria-label="Language selector">
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"
            ></line><path
              d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            ></path></svg
          ><span id="lp-lang-label">English</span><svg
            class="lp-chevron lp-chevron--lang"
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg
          >
        </summary>
        <div class="lp-lang-panel" role="listbox" aria-label="Select language">
          <button
            class="lp-lang-opt"
            type="button"
            role="option"
            data-lang="en"
            aria-selected="true">English</button
          >
          <button
            class="lp-lang-opt"
            type="button"
            role="option"
            data-lang="ko"
            aria-selected="false">한국어</button
          >
          <button
            class="lp-lang-opt"
            type="button"
            role="option"
            data-lang="ja"
            aria-selected="false">日本語</button
          >
        </div>
      </details>

      <AuthNavLink pathname={pathname} client:load />

      <details class="lp-nav-download">
        <summary class="lp-btn-download" aria-label="Download — choose platform">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            ><path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path></svg
          ><span data-i18n="nav.download">Download</span><svg
            class="lp-chevron lp-chevron--download"
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg
          >
        </summary>
        <div class="lp-download-panel" role="group" aria-label="Download by platform">
          <a class="lp-download-row lp-download-row--link" href={downloadHashHref}>macOS</a>
          <p class="lp-download-row lp-download-row--soon">
            Windows <span class="lp-download-soon" data-i18n="nav.coming_soon">Coming soon</span>
          </p>
          <p class="lp-download-row lp-download-row--soon">
            Linux <span class="lp-download-soon" data-i18n="nav.coming_soon">Coming soon</span>
          </p>
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  .lp-nav {
    --lp-nav-pad-x: 2rem;
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0;
    min-height: 3.75rem;
    border-bottom: none;
    box-shadow: none;
    background: var(--ol-bg);
  }

  .lp-nav-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 96rem;
    margin: 0 auto;
    padding: 0 var(--lp-nav-pad-x);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 3.75rem;
  }

  .lp-nav-start {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    flex: 0 1 auto;
    position: relative;
    z-index: 2;
  }

  .lp-brand-tagline-text {
    display: block;
    font-family: var(--font-lp-accent-serif);
    font-size: 1.1875rem;
    font-weight: 700;
    font-style: normal;
    letter-spacing: -0.015em;
    color: var(--lp-ink);
    line-height: 1;
  }

  .lp-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--lp-ink);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
    flex-shrink: 0;
    border-radius: 0.5rem;
    outline-offset: 3px;
  }

  .lp-nav-links {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.125rem;
    flex: none;
    min-width: 0;
    pointer-events: auto;
  }

  .lp-nav-links a {
    color: var(--lp-muted);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.35rem 0.7rem;
    border-radius: 0.5rem;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }

  .lp-nav-links a:hover {
    color: var(--ol-text);
    background: color-mix(in oklab, var(--ol-text) 5.5%, transparent);
  }

  .lp-nav-links a[aria-current='page'] {
    color: var(--ol-text);
    background: color-mix(in oklab, var(--ol-text) 6.5%, transparent);
  }

  .lp-nav-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    padding-left: 0;
    margin-left: 0;
    position: relative;
    z-index: 2;
  }

  /* ── Language picker ── */
  .lp-nav-lang {
    position: relative;
    display: inline-block;
    list-style: none;
  }

  .lp-nav-lang summary.lp-btn-lang {
    list-style: none;
  }

  .lp-nav-lang summary.lp-btn-lang::-webkit-details-marker {
    display: none;
  }

  .lp-nav-lang summary.lp-btn-lang:focus-visible {
    outline: 2px solid rgba(64, 120, 242, 0.4);
    outline-offset: 2px;
  }

  .lp-btn-lang {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    border: 1px solid color-mix(in oklab, var(--ol-border) 48%, transparent);
    background: color-mix(in oklab, var(--lp-surface) 78%, transparent);
    color: var(--lp-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    padding: 0.3125rem 0.65rem;
    border-radius: 999px;
    box-shadow: none;
    transition:
      color 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
    user-select: none;
  }

  .lp-btn-lang:hover {
    color: var(--ol-text);
    border-color: color-mix(in oklab, var(--ol-border) 72%, transparent);
    background: color-mix(in oklab, var(--lp-surface) 92%, transparent);
  }

  .lp-nav-lang[open] > .lp-btn-lang {
    color: var(--ol-text);
    border-color: color-mix(in oklab, var(--ol-border) 72%, transparent);
  }

  .lp-chevron--lang {
    opacity: 0.5;
    flex-shrink: 0;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .lp-nav-lang[open] .lp-chevron--lang {
    transform: rotate(180deg);
    opacity: 0.75;
  }

  .lp-lang-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.375rem);
    z-index: 100;
    min-width: 8rem;
    padding: 0.3rem;
    background: var(--lp-surface, #fff);
    border: 1px solid color-mix(in oklab, var(--ol-border) 80%, transparent);
    border-radius: 0.5rem;
    box-shadow:
      0 4px 24px rgba(56, 58, 66, 0.08),
      0 1px 3px rgba(56, 58, 66, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .lp-lang-opt {
    width: 100%;
    text-align: left;
    border: none;
    background: transparent;
    padding: 0.45rem 0.65rem;
    border-radius: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ol-text2, #696c77);
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .lp-lang-opt:hover {
    background: color-mix(in oklab, var(--ol-text, #383a42) 5.5%, transparent);
    color: var(--ol-text, #383a42);
  }

  .lp-lang-opt[aria-selected='true'] {
    color: var(--ol-text, #383a42);
    font-weight: 600;
  }

  /* ── Sign in ──
     `:global(...)` because `.lp-nav-signin` now lives on the Solid
     AuthNavLink's rendered anchor, which does not receive Astro's
     scoped `data-astro-cid-*` attribute. Without :global the scoped
     selector would miss the element and styling falls back to the
     browser default anchor. */
  :global(.lp-nav-signin) {
    color: var(--lp-muted);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.3125rem 0.75rem;
    border-radius: 999px;
    letter-spacing: -0.01em;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }

  :global(.lp-nav-signin:hover) {
    color: var(--ol-text);
    background: color-mix(in oklab, var(--ol-text) 5.5%, transparent);
  }

  :global(.lp-nav-signin[aria-current='page']) {
    color: var(--ol-text);
    background: color-mix(in oklab, var(--ol-text) 6.5%, transparent);
  }

  /* ── Download ── */
  .lp-nav-download {
    position: relative;
    display: inline-block;
    list-style: none;
  }

  .lp-nav-download summary.lp-btn-download {
    list-style: none;
  }

  .lp-nav-download summary.lp-btn-download::-webkit-details-marker {
    display: none;
  }

  .lp-nav-download summary.lp-btn-download:focus-visible {
    outline: 2px solid rgba(64, 120, 242, 0.4);
    outline-offset: 2px;
  }

  .lp-btn-download {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--ol-text);
    color: var(--theme-ol-on-ink);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    padding: 0.375rem 0.95rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--ol-text) 88%, #000 12%);
    box-shadow: none;
    cursor: pointer;
    user-select: none;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      opacity 0.2s ease;
  }

  .lp-btn-download:hover {
    background: var(--theme-ol-ink-hover);
    border-color: var(--theme-ol-ink-hover);
    opacity: 0.96;
  }

  .lp-btn-download:active {
    opacity: 0.88;
  }

  .lp-nav-download[open] > .lp-btn-download {
    background: var(--theme-ol-ink-hover);
    border-color: var(--theme-ol-ink-hover);
    opacity: 0.96;
  }

  .lp-chevron {
    opacity: 0.55;
  }

  .lp-chevron--download {
    opacity: 0.5;
    flex-shrink: 0;
    transition:
      transform 0.22s ease,
      opacity 0.2s ease;
  }

  .lp-nav-download[open] .lp-chevron--download {
    transform: rotate(180deg);
    opacity: 0.75;
  }

  .lp-download-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.375rem);
    z-index: 100;
    min-width: 12.5rem;
    padding: 0.35rem;
    background: var(--lp-surface);
    border: 1px solid color-mix(in oklab, var(--ol-border) 80%, transparent);
    border-radius: 0.5rem;
    box-shadow:
      0 4px 24px rgba(56, 58, 66, 0.08),
      0 1px 3px rgba(56, 58, 66, 0.06);
  }

  .lp-download-row {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--ol-text2);
  }

  a.lp-download-row--link {
    color: var(--ol-text);
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.18s ease,
      color 0.18s ease;
  }

  a.lp-download-row--link:hover {
    background: color-mix(in oklab, var(--ol-text) 5.5%, transparent);
    color: var(--ol-text);
  }

  .lp-download-row--soon {
    cursor: default;
    color: var(--ol-text2);
  }

  .lp-download-soon {
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--lp-faint);
  }

  @media (max-width: 48rem) {
    .lp-nav {
      --lp-nav-pad-x: 1rem;
    }

    .lp-nav-inner {
      gap: 0.65rem;
    }

    .lp-nav-actions {
      padding-left: 0.65rem;
      margin-left: 0;
      gap: 0.3rem;
    }

    .lp-nav-lang {
      display: none;
    }

    :global(.lp-nav-signin) {
      display: none;
    }

    .lp-btn-lang {
      font-size: 0.75rem;
      padding: 0.3rem 0.55rem;
    }

    :global(.lp-nav-signin) {
      padding: 0.3125rem 0.55rem;
      font-size: 0.75rem;
    }

    .lp-btn-download {
      padding: 0.35rem 0.75rem;
      font-size: 0.75rem;
    }

    .lp-brand-tagline-text {
      font-size: 1.0625rem;
    }

    .lp-nav-links {
      display: none;
      position: static;
      transform: none;
    }
  }
</style>

<textarea hidden id="kuku-i18n-payload">{i18nPayloadJson}</textarea>

<script is:inline>
  (function () {
    const STORAGE_KEY = 'kuku_lang';
    const DEFAULT_LANG = 'en';

    function hasOwn(object, key) {
      return Object.hasOwn(object, key);
    }

    function readJsonScript(id, fallback) {
      const el = document.getElementById(id);
      if (!el || !el.textContent) return fallback;

      try {
        return JSON.parse(el.textContent);
      } catch {
        return fallback;
      }
    }

    const i18nPayload = readJsonScript('kuku-i18n-payload', {});
    const T = i18nPayload.messages || {};
    const LANG_LABELS = i18nPayload.labels || {};

    function isSupportedLang(lang) {
      return typeof lang === 'string' && hasOwn(T, lang);
    }

    function storedLang() {
      const stored = localStorage.getItem(STORAGE_KEY);
      return isSupportedLang(stored) ? stored : null;
    }

    function resolvedLang() {
      return storedLang() || document.documentElement.lang;
    }

    function catalogFor(lang) {
      return (isSupportedLang(lang) && T[lang]) || T[DEFAULT_LANG] || {};
    }

    function translate(lang, key) {
      const catalog = catalogFor(lang);
      if (hasOwn(catalog, key)) return catalog[key];

      const fallback = catalogFor(DEFAULT_LANG);
      return hasOwn(fallback, key) ? fallback[key] : undefined;
    }

    function applyLang(lang, persist) {
      const nextLang = isSupportedLang(lang) ? lang : DEFAULT_LANG;

      document.querySelectorAll('[data-i18n]').forEach(function (el) {
        const key = el.getAttribute('data-i18n');
        const value = key ? translate(nextLang, key) : undefined;
        if (value !== undefined) el.textContent = value;
      });

      document.querySelectorAll('[data-i18n-html]').forEach(function (el) {
        const key = el.getAttribute('data-i18n-html');
        const value = key ? translate(nextLang, key) : undefined;
        if (value !== undefined) el.innerHTML = value;
      });

      document.querySelectorAll('[data-i18n-placeholder]').forEach(function (el) {
        const key = el.getAttribute('data-i18n-placeholder');
        const value = key ? translate(nextLang, key) : undefined;
        if (value !== undefined) el.setAttribute('placeholder', value);
      });

      const label = document.getElementById('lp-lang-label');
      if (label) label.textContent = LANG_LABELS[nextLang] || nextLang;

      document.querySelectorAll('[data-lang]').forEach(function (btn) {
        btn.setAttribute(
          'aria-selected',
          btn.getAttribute('data-lang') === nextLang ? 'true' : 'false',
        );
      });

      document.documentElement.lang = nextLang;
      if (persist) localStorage.setItem(STORAGE_KEY, nextLang);
    }

    window.__kukuI18n = {
      messages: T,
      labels: LANG_LABELS,
      applyLang(lang) {
        applyLang(lang, true);
      },
      t(key, lang) {
        return translate(isSupportedLang(lang) ? lang : resolvedLang(), key);
      },
    };

    function ready(fn) {
      if (document.readyState !== 'loading') fn();
      else document.addEventListener('DOMContentLoaded', fn);
    }

    ready(function () {
      applyLang(resolvedLang(), false);
    });

    window.addEventListener('kuku:lang-refresh', function () {
      applyLang(resolvedLang(), false);
    });

    document.addEventListener('click', function (e) {
      if (!(e.target instanceof Element)) return;

      const btn = e.target.closest('[data-lang]');
      if (btn) {
        const lang = btn.getAttribute('data-lang');
        if (isSupportedLang(lang)) {
          applyLang(lang, true);
          const detailsPanel = btn.closest('details');
          if (detailsPanel) detailsPanel.removeAttribute('open');
        }
        return;
      }

      const langMenu = document.getElementById('lp-nav-lang');
      if (langMenu && langMenu.hasAttribute('open') && !langMenu.contains(e.target)) {
        langMenu.removeAttribute('open');
      }
    });
  })();
</script>
