    color: var(--ku-text3);
    padding: 0;
    cursor: default;
  }
  [data-phase='graph'] .am-rt-tab-graph {
    color: var(--ku-text2);
    box-shadow: 0 0 0 1px var(--ku-border-focus);
  }
  [data-phase='ai-chat'] .am-rt-tab-ai {
    color: var(--ku-text2);
    box-shadow: 0 0 0 1px var(--ku-border-focus);
  }

  .am-rp-content {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .am-panel-graph,
  .am-panel-ai {
    display: none;
    flex: 1;
    min-height: 0;
    flex-direction: column;
    overflow: hidden;
  }
  [data-phase='graph'] .am-panel-graph {
    display: flex;
  }
  [data-phase='ai-chat'] .am-panel-ai {
    display: flex;
  }

  .am-graph-canvas {
    flex: 1;
    min-height: 0;
    background: var(--ol-page);
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 10px 8px 0;
    position: relative;
  }
  .am-graph-svg {
    width: 100%;
    height: 100%;
    max-height: 400px;
    display: block;
  }
  .am-g-cluster {
    opacity: 0;
  }
  .am-gc0 {
    fill: hsla(0, 72%, 62%, 0.12);
    stroke: hsla(0, 72%, 62%, 0.22);
    stroke-width: 1;
  }
  .am-gc1 {
    fill: hsla(137.5, 72%, 62%, 0.1);
    stroke: hsla(137.5, 72%, 62%, 0.2);
    stroke-width: 1;
  }
  .am-gc2 {
    fill: hsla(275, 72%, 62%, 0.09);
    stroke: hsla(275, 72%, 62%, 0.18);
    stroke-width: 1;
  }
  .am-glink {
    fill: none;
    stroke: rgba(0, 0, 0, 0.12);
    stroke-width: 1.1;
  }
  .am-gnode,
  .am-gnode-hub {
    opacity: 0;
  }
  .am-gnode-hub .am-glow {
    animation: am-hub-pulse 2.8s ease-out infinite;
  }
  @keyframes am-hub-pulse {
    0% {
      transform: scale(0.85);
      opacity: 0.55;
    }
    100% {
      transform: scale(1.45);
      opacity: 0;
    }
  }
  .am-graph-hud {
    flex-shrink: 0;
    padding: 6px 8px 8px;
    display: flex;
    justify-content: center;
    background: linear-gradient(to top, var(--ku-bg1), transparent);
  }
  .am-graph-hud-inner {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 3px 6px;
    border-radius: 3px;
    border: 1px solid var(--ku-border);
    background: color-mix(in oklab, var(--ol-page) 95%, transparent);
    font-size: 11px;
    color: var(--ku-text3);
  }
  .am-gh-btn {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
    cursor: default;
  }
  .am-gh-zoom {
    margin-left: 4px;
    padding-left: 6px;
    border-left: 1px solid var(--ku-border);
    font-variant-numeric: tabular-nums;
    font-size: 10px;
  }

  /* AI Chat */
  .am-chat-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 40px;
    padding: 0 10px;
    border-bottom: 1px solid color-mix(in oklab, var(--ku-border) 72%, transparent);
    flex-shrink: 0;
    background: var(--ol-page);
  }
  .am-chat-status {
    font-size: 12px;
    color: var(--ku-text3);
  }
  .am-chat-status-busy {
    color: var(--ku-info);
  }
  .am-chat-status-gen {
    color: var(--ku-success);
  }
  .am-icon-btn {
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    border-radius: 2px;
    color: var(--ku-text3);
    cursor: default;
    font-size: 13px;
  }
  .am-chat-msgs {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 12px 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--ol-page);
    align-items: stretch;
  }
  .am-msg-user {
    display: flex;
    justify-content: flex-start;
  }
  .am-bubble-user {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid color-mix(in oklab, var(--ku-border) 72%, transparent);
    background: color-mix(in oklab, var(--ol-page) 88%, transparent);
    color: var(--ku-text);
    padding: 9px 11px;
    font-size: 12.5px;
    line-height: 1.55;
    box-shadow: 0 1px 2px rgba(15, 15, 15, 0.04);
  }
  .am-tool-block {
    margin: 0 2px;
    padding: 6px;
    border-radius: 10px;
    border: 1px solid color-mix(in oklab, var(--ku-border) 78%, transparent);
    background: color-mix(in oklab, var(--ol-page) 95%, transparent);
    box-shadow: 0 1px 1px rgba(15, 15, 15, 0.05);
  }
  .am-tool-row {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11.5px;
    padding: 5px 6px;
    color: var(--ku-text2);
    border-radius: 8px;
    min-height: 28px;
  }
  .am-tool-row + .am-tool-row {
    margin-top: 2px;
  }
  .am-tool-row:hover {
    background: color-mix(in oklab, var(--ku-text) 7%, transparent);
  }
  .am-tool-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: color-mix(in oklab, var(--ku-text3) 74%, transparent);
    flex-shrink: 0;
    position: relative;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--ku-border-focus) 58%, transparent);
  }
  .am-tool-pulse {
    background: var(--ku-info);
    animation: am-pulse 1.2s ease-in-out infinite;
  }
  @keyframes am-pulse {
    0%,
    100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.06);
    }
  }
  .am-tool-ok {
    background: var(--ku-success);
    animation: none;
    opacity: 1;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--ku-success) 55%, transparent);
  }
  .am-tool-check {
    color: var(--ku-success);
    font-size: 10px;
    font-weight: 700;
    width: 12px;
    flex-shrink: 0;
    text-align: center;
    opacity: 0.75;
    line-height: 1;
  }
  .am-tool-done .am-tool-check {
    opacity: 1;
  }
  .am-tool-check-hid {
    display: none !important;
  }
  #am-tool-3.am-tool-done .am-tool-dot {
    display: none;
  }
  .am-ai-patch {
    margin: 0;
    padding: 0 0 0 10px;
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--ku-text2);
    border-left: 3px solid var(--ku-success);
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition:
      opacity 0.5s cubic-bezier(0.33, 1, 0.68, 1),
      max-height 0.5s cubic-bezier(0.33, 1, 0.68, 1),
      margin 0.45s ease;
  }
  .am-ed--patched .am-ai-patch {
    opacity: 1;
    max-height: 6.5rem;
    margin-top: 0.4rem;
    margin-bottom: 0.15rem;
  }
  .am-glink-dim {
    opacity: 0.45;
  }
  .am-tool-label {
    color: var(--ku-text);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .am-tool-detail {
    margin-left: auto;
