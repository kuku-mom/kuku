    color: var(--ku-text3);
    opacity: 0.88;
  }
  .am-chat-input-ft {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 10px;
    background: color-mix(in oklab, var(--ku-text) 4%, transparent);
  }
  .am-mode-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 11px;
    border-radius: 6px;
    border: none;
    background: color-mix(in oklab, var(--ku-text) 10%, transparent);
    font-size: 11px;
    font-weight: 500;
    text-transform: capitalize;
    color: var(--ku-text2);
