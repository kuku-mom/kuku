    list-style: disc;
  }
  .am-li {
    margin: 0.2em 0;
  }
  .am-pre {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.82em;
    line-height: 1.55;
    background: var(--ol-page2);
    border: 1px solid color-mix(in oklab, var(--ku-border) 72%, transparent);
    border-radius: 6px;
    padding: 0.75em 1em;
    margin: 0.75em 0;
    overflow-x: auto;
    white-space: pre;
  }
  .syn-comment {
    color: var(--syn-comment);
    font-style: italic;
  }
  .syn-kw {
    color: var(--syn-kw);
  }
  .syn-type {
    color: var(--syn-type);
  }
  .syn-fn {
    color: var(--syn-fn);
  }
  .syn-param {
    color: var(--syn-param);
  }
  .syn-p {
    color: var(--ku-text);
  }
  .syn-str {
    color: var(--syn-str);
  }

  .am-tab2::before {
    content: '  ';
    white-space: pre;
  }

  .am-pre-live {
    position: relative;
    white-space: normal;
  }

  .am-precode-stack {
    display: block;
    white-space: normal;
  }

  .am-crow {
    display: block;
    white-space: pre;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .am-crow--hid {
    display: none;
  }

  .am-crow--glow {
    background: linear-gradient(90deg, rgba(80, 161, 79, 0.16), transparent 92%);
    border-radius: 3px;
    margin: 0 -0.25em;
    padding: 0.06em 0.25em;
    transition: background 0.45s ease;
  }

  .am-crow--mut {
    background: linear-gradient(90deg, rgba(64, 120, 242, 0.1), transparent 90%);
    border-radius: 3px;
    margin: 0 -0.25em;
    padding: 0.06em 0.25em;
    transition: background 0.5s ease;
  }

  #am-crow-map-arg.am-code-ix {
    background: rgba(80, 161, 79, 0.35);
    border-radius: 2px;
    padding: 0 0.1em;
    transition: background 0.35s ease;
  }

  .am-pre--ai-focus {
    box-shadow:
      0 0 0 1px rgba(64, 120, 242, 0.28),
      0 6px 20px rgba(64, 120, 242, 0.08);
    transition: box-shadow 0.45s ease;
  }

  .am-pre-caret {
    display: none;
    position: absolute;
    right: 14px;
    bottom: 12px;
    width: 2px;
    height: 13px;
    background: var(--ol-accent);
    border-radius: 1px;
    animation: am-blink 1.05s ease-in-out infinite;
  }

  .am-pre--caret-on .am-pre-caret {
    display: block;
  }

  .am-doc-kr4 {
    margin: 0 0 0.5em;
    padding: 0.42em 0.58em;
    border-radius: 5px;
    background: rgba(80, 161, 79, 0.09);
    box-shadow: inset 0 0 0 1px rgba(80, 161, 79, 0.22);
    font-size: 14px;
    line-height: 1.45;
    transition:
      opacity 0.45s ease,
      max-height 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      margin 0.45s ease,
      padding 0.45s ease;
  }

  .am-doc-kr4--hid {
    opacity: 0;
    max-height: 0;
    margin: 0;
    padding: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .am-kr-tag {
    color: var(--ku-success);
    font-weight: 700;
    margin-right: 0.28em;
  }

  .am-ai-patch-inner {
    display: inline;
  }

  .am-tasklist {
    margin: 0.45em 0;
  }
  .am-task {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin: 0.2em 0;
  }
  .am-cb {
    display: flex;
    width: 1.45em;
    height: 1.45em;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.15em;
  }
  .am-cb-ctrl {
    width: 0.95em;
    height: 0.95em;
    border: 1px solid var(--ku-border-focus);
    border-radius: 3px;
    background: var(--ku-bg0);
  }
  .am-cb-ctrl-done {
    background: var(--ku-text);
    border-color: var(--ku-text);
    position: relative;
  }
  .am-cb-ctrl-done::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.4em;
    height: 0.22em;
    border: 2px solid var(--ku-bg0);
    border-top: 0;
    border-right: 0;
    transform: translate(-52%, -58%) rotate(-45deg);
  }
  .am-task-txt {
    flex: 1;
    min-width: 0;
    color: var(--ku-text);
  }

  .am-wikiline {
    margin-top: 1.25em;
    font-size: 14px;
    line-height: 1.6;
  }
  .am-muted {
    color: var(--ku-text3);
    margin-right: 0.5em;
  }
  .am-wl-chunk {
    display: inline-block;
    opacity: 0;
    transform: translateY(5px);
    color: var(--ol-accent);
    font-weight: 500;
    padding: 0.08em 0.35em;
    border-radius: 4px;
    background: var(--ol-accent-dim);
    margin: 0 0.12em;
  }
  .am-wl-gap {
    color: var(--ku-text3);
    background: transparent;
    font-weight: 400;
    padding: 0 0.1em;
  }

  .am-cursor-doc {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--ku-text);
    vertical-align: text-bottom;
    margin-left: 2px;
    opacity: 0;
    border-radius: 1px;
    animation: am-blink 1.05s ease-in-out infinite;
  }
  @keyframes am-blink {
    0%,
    42% {
      opacity: 1;
    }
    50%,
    92% {
      opacity: 0.15;
    }
    100% {
      opacity: 1;
    }
  }

  .am-tab-ic-graph {
    display: inline-flex;
    line-height: 0;
  }

  .am-kuku-icon {
    display: block;
  }

  /* Right panel */
  .am-right {
    width: 0;
    flex-shrink: 0;
    overflow: hidden;
    transition: width 0.62s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-phase='graph'] .am-right,
  [data-phase='ai-chat'] .am-right {
    width: var(--am-panel-w);
  }

  .am-right-inner {
    width: var(--am-panel-w);
    min-width: var(--am-panel-w);
    height: 100%;
    display: flex;
    flex-direction: column;
    background: var(--ol-page);
    border-left: 1px solid rgba(0, 0, 0, 0.07);
  }
  .am-rtbar {
    height: 38px;
    display: flex;
    align-items: center;
    padding: 0 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    flex-shrink: 0;
    background: var(--ol-page);
  }
  .am-rt-tabs {
    display: flex;
    gap: 2px;
  }
  .am-rt-tab {
    width: 28px;
    height: 28px;
