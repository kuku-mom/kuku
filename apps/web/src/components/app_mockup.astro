  .am-mode-btn:hover {
    background: color-mix(in oklab, var(--ku-text) 14%, transparent);
    color: var(--ku-text);
  }
  .am-caret {
    font-size: 8px;
    line-height: 1;
    opacity: 0.65;
    color: var(--ku-text3);
  }
  .am-chat-hint {
    font-size: 10px;
    line-height: 1.35;
    color: var(--ku-text3);
    text-align: right;
    min-width: 0;
  }
  .am-kbd {
    display: inline-block;
    padding: 1px 5px;
    border-radius: 4px;
