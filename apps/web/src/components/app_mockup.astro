<script is:inline>
  (function () {
    const root = document.getElementById('am-demo');
    if (!root) return;

    const AM_KEYS = {
      slashHeading: 'mock.anim.slash_heading',
      patchCallout: 'mock.anim.patch_callout',
      fullStrong: 'mock.anim.full_strong',
      fullRest: 'mock.anim.full_rest',
      taskLine: 'mock.anim.task_line',
      running: 'mock.anim.running',
      writing: 'mock.anim.writing',
      generating: 'mock.anim.generating',
      idle: 'mock.anim.idle',
    };

    function amT(key) {
      const i18nKey = AM_KEYS[key];
      const value = window.__kukuI18n && window.__kukuI18n.t(i18nKey);
      return value || i18nKey;
    }

    const phases = ['editor', 'graph', 'ai-chat'];
    const durations = [11200, 7800, 17600];
    const ED_SLASH_OFFSET = 3920;
    const easeOut = 'cubic-bezier(0.22, 1, 0.36, 1)';
    const easeSoft = 'cubic-bezier(0.33, 1, 0.68, 1)';
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let idx = 0;
    let timers = [];

    function clearTimers() {
      timers.forEach(clearTimeout);
      timers = [];
    }
    function delay(fn, ms) {
      const t = setTimeout(fn, ms);
      timers.push(t);
      return t;
    }

    function scrollWithin(container, target, block) {
      if (!container || !target) return;
      const c = container.getBoundingClientRect();
      const t = target.getBoundingClientRect();
      const margin = 10;
      let delta = 0;
      if (block === 'center') {
        delta = t.top - c.top - (c.height - t.height) / 2;
      } else {
        if (t.top < c.top + margin) delta = t.top - c.top - margin;
        else if (t.bottom > c.bottom - margin) delta = t.bottom - c.bottom + margin;
        else return;
      }
      const next = Math.max(0, container.scrollTop + delta);
      if (reduceMotion) {
        container.scrollTop = next;
        return;
      }
      container.scrollTo({ top: next, behavior: 'smooth' });
    }

    function smoothScrollEditorTop() {
      const el = document.getElementById('am-ed-scroll');
      if (!el) return;
      el.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
    }

    function resetEditorAnim() {
      const strong = document.getElementById('am-type-strong');
      const rest = document.getElementById('am-type-rest');
      const cursor = document.getElementById('am-doc-cursor');
      const liveTxt = document.getElementById('am-task-live-txt');
      const cbCtrl = document.getElementById('am-cb-ctrl-live');
      const chunks = root.querySelectorAll('.am-wl-chunk');
      const patchInner = document.getElementById('am-ai-patch-inner');
      const kr4 = document.getElementById('am-doc-kr4');
      const crowAi1 = document.getElementById('am-crow-ai-1');
      const crowAi2 = document.getElementById('am-crow-ai-2');
      const mapArg = document.getElementById('am-crow-map-arg');
      const preLive = document.getElementById('am-pre-live');
      const preCaret = document.getElementById('am-pre-caret');

      if (strong) strong.textContent = '';
      if (rest) rest.textContent = '';
      if (liveTxt) liveTxt.textContent = '';
      if (patchInner) patchInner.textContent = '';
      if (kr4) kr4.classList.add('am-doc-kr4--hid');
      crowAi1?.classList.add('am-crow--hid');
      crowAi2?.classList.add('am-crow--hid');
      crowAi1?.classList.remove('am-crow--glow');
      crowAi2?.classList.remove('am-crow--glow');
      if (mapArg) {
        mapArg.textContent = 'files';
        mapArg.classList.remove('am-code-ix');
      }
      document.getElementById('am-crow-promise')?.classList.remove('am-crow--mut');
      preLive?.classList.remove('am-pre--caret-on', 'am-pre--ai-focus');
      if (preCaret) preCaret.style.opacity = '';
      if (cbCtrl) {
        cbCtrl.classList.remove('am-cb-ctrl-done');
        const parent = document.getElementById('am-cb-live');
        parent?.classList.remove('am-cb-done');
      }
      chunks.forEach((c) => {
        c.style.opacity = '0';
        c.style.transform = 'translateY(6px)';
      });
      if (cursor) {
        cursor.style.opacity = '0';
      }
      const edRoot = document.getElementById('am-ed-root');
      edRoot?.classList.remove('am-ed--patched');
      const slashBlock = document.getElementById('am-slash-block');
      const slashTyped = document.getElementById('am-slash-typed');
      const slashPop = document.getElementById('am-slash-pop');
      const slashCaret = document.getElementById('am-slash-caret');
      slashBlock?.classList.remove('am-slash-open', 'am-slash-block--done');
      if (slashTyped) slashTyped.textContent = '';
      slashPop?.setAttribute('aria-hidden', 'true');
      slashPop
        ?.querySelectorAll('.am-slash-item')
        ?.forEach((el) => el.classList.remove('am-slash-item--act'));
      slashCaret?.classList.remove('am-slash-caret--on');
      const h2Text = document.getElementById('am-h2-slash-text');
      const h2Ins = document.getElementById('am-h2-slash-insert');
      const h2Caret = document.getElementById('am-h2-slash-caret');
      if (h2Text) h2Text.textContent = '';
      h2Ins?.classList.remove('am-h2-slash-has-text');
      h2Caret?.classList.remove('am-h2-slash-caret--on');
    }

    function scheduleHumanType(el, text, t0) {
      if (!el || !text) return t0;
      let acc = t0;
      for (let c = 0; c <= text.length; c++) {
        const n = c;
        delay(() => {
          el.textContent = text.slice(0, n);
        }, acc);
        if (c < text.length) {
          const ch = text[c];
          let pause = 46 + Math.round(Math.random() * 26);
          if (ch === ' ') pause += 36;
          if (',.;:'.includes(ch)) pause += 55;
          acc += pause;
        }
      }
      return acc;
    }

    function runSlashMenuIntro() {
      const block = document.getElementById('am-slash-block');
      const typed = document.getElementById('am-slash-typed');
      const caret = document.getElementById('am-slash-caret');
      const pop = document.getElementById('am-slash-pop');
      const items = pop ? [...pop.querySelectorAll('[data-am-slash-i]')] : [];
      const h2Text = document.getElementById('am-h2-slash-text');
      const h2Ins = document.getElementById('am-h2-slash-insert');
      const h2Caret = document.getElementById('am-h2-slash-caret');

      function setSlashActive(i) {
        items.forEach((el) => {
          const j = Number(el.getAttribute('data-am-slash-i'));
          el.classList.toggle('am-slash-item--act', j === i);
        });
      }

      delay(() => caret?.classList.add('am-slash-caret--on'), 180);
      scheduleTypewriter(typed, '/', 420, 28);
      delay(() => {
        block?.classList.add('am-slash-open');
        pop?.setAttribute('aria-hidden', 'false');
      }, 560);
      const seq = [0, 1, 2, 3, 2, 1, 0];
      let navT = 820;
      seq.forEach((seqIndex, k) => {
        delay(() => setSlashActive(seqIndex), navT);
        if (k < seq.length - 1) {
          navT += 118 + ((k * 23 + (seqIndex % 3) * 11) % 52);
        }
      });
      const dwellOnChoice = 480;
      const menuCloseAt = navT + dwellOnChoice;
      delay(() => {
        block?.classList.remove('am-slash-open');
        pop?.setAttribute('aria-hidden', 'true');
      }, menuCloseAt);
      const applyBlockAt = menuCloseAt + 140;
      delay(() => {
        block?.classList.add('am-slash-block--done');
        if (typed) typed.textContent = '';
        caret?.classList.remove('am-slash-caret--on');
      }, applyBlockAt);
      const headingReadyAt = applyBlockAt + 260;
      delay(() => h2Caret?.classList.add('am-h2-slash-caret--on'), headingReadyAt);
      delay(() => h2Ins?.classList.add('am-h2-slash-has-text'), headingReadyAt + 70);
      const typeEnd = scheduleHumanType(h2Text, amT('slashHeading'), headingReadyAt + 95);
      delay(() => h2Caret?.classList.remove('am-h2-slash-caret--on'), typeEnd + 260);
    }

    function scheduleTypewriter(el, text, t0, charMs) {
      if (!el || !text) return;
      let acc = t0;
      for (let i = 0; i <= text.length; i++) {
        const n = i;
        delay(() => {
          el.textContent = text.slice(0, n);
        }, acc);
        if (n < text.length) {
          const ch = text[n];
          acc += charMs + (ch === ' ' ? 14 : 0);
        }
      }
    }

    function runEditorAnim() {
      resetEditorAnim();
      runSlashMenuIntro();
      const off = ED_SLASH_OFFSET;
      const fullStrong = amT('fullStrong');
      const fullRest = amT('fullRest');
      const taskLine = amT('taskLine');
      const strongEl = document.getElementById('am-type-strong');
      const restEl = document.getElementById('am-type-rest');
      const cursor = document.getElementById('am-doc-cursor');
      const liveTxt = document.getElementById('am-task-live-txt');
      const scrollEl = document.getElementById('am-ed-scroll');

      let t = off + 420;
      const typeChunk = (el, text, start, baseSpeed) => {
        if (!el || !text) return;
        let j = 0;
        const tick = () => {
          j++;
          el.textContent = text.slice(0, j);
          if (j >= text.length) return;
          const ch = text[j];
          let pause = baseSpeed + Math.round(Math.random() * 18);
          if ('.,;:'.includes(ch)) pause += 110;
          if (ch === ' ') pause += 35;
          delay(tick, pause);
        };
        delay(tick, start);
      };

      typeChunk(strongEl, fullStrong, t, 52);
      t += estimateTypeMs(fullStrong, 52) + 280;
      typeChunk(restEl, fullRest, t, 36);
      t += estimateTypeMs(fullRest, 36) + 320;
      delay(() => {
        if (cursor) {
          cursor.style.transition = `opacity 0.55s ${easeSoft}`;
          cursor.style.opacity = '1';
        }
      }, t);

      delay(() => {
        typeChunk(liveTxt, taskLine, 0, 44);
      }, off + 980);

      delay(() => {
        const cbCtrl = document.getElementById('am-cb-ctrl-live');
        const parent = document.getElementById('am-cb-live');
        cbCtrl?.classList.add('am-cb-ctrl-done');
        parent?.classList.add('am-cb-done');
      }, off + 3100);

      const chunks = root.querySelectorAll('.am-wl-chunk');
      chunks.forEach((el, i) => {
        delay(
          () => {
            el.style.transition = `opacity 0.55s ${easeOut}, transform 0.55s ${easeOut}`;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          },
          off + 1280 + i * 340,
        );
      });

      delay(() => {
        if (!scrollEl) return;
        scrollEl.scrollTo({
          top: scrollEl.scrollHeight,
          behavior: reduceMotion ? 'auto' : 'smooth',
        });
      }, off + 5200);
    }

    function animateGraph() {
      const links = root.querySelectorAll('.am-glink');
      const nodes = root.querySelectorAll('.am-gnode');

      links.forEach((path) => {
        const len = path.getTotalLength?.() ?? 120;
        path.style.strokeDasharray = `${len}`;
        path.style.strokeDashoffset = `${len}`;
        path.style.transition = 'none';
      });
      nodes.forEach((n) => {
        n.style.transition = 'none';
        n.style.opacity = '0';
      });

      delay(() => {
        links.forEach((path, i) => {
          path.style.transition = `stroke-dashoffset 1.15s ${easeSoft} ${i * 55}ms`;
          path.style.strokeDashoffset = '0';
        });
      }, 200);

      root.querySelectorAll('.am-g-cluster').forEach((c, i) => {
        c.style.opacity = '0';
        delay(
          () => {
            c.style.transition = `opacity 0.75s ${easeSoft}`;
            c.style.opacity = '1';
          },
          120 + i * 95,
        );
      });

      nodes.forEach((n, i) => {
        delay(
          () => {
            n.style.transition = `opacity 0.65s ${easeOut}`;
            n.style.opacity = '1';
          },
          320 + i * 110,
        );
      });

      const hub = root.querySelector('.am-gnode-hub .am-glow');
      if (hub) {
        hub.style.animation = 'none';
        void hub.getBoundingClientRect();
        hub.style.animation = '';
      }
    }

    function animateChat() {
      const user = document.getElementById('am-cm-user');
      const tools = document.getElementById('am-cm-tools');
      const typing = document.getElementById('am-cm-typing');
      const resp = document.getElementById('am-cm-resp');
      const status = document.getElementById('am-chat-status');
      const t1 = document.getElementById('am-tool-1');
      const t2 = document.getElementById('am-tool-2');
      const t3 = document.getElementById('am-tool-3');
      const edRoot = document.getElementById('am-ed-root');
      const patchInner = document.getElementById('am-ai-patch-inner');
      const kr4 = document.getElementById('am-doc-kr4');
      const crowAi1 = document.getElementById('am-crow-ai-1');
      const crowAi2 = document.getElementById('am-crow-ai-2');
      const mapArg = document.getElementById('am-crow-map-arg');
      const crowPromise = document.getElementById('am-crow-promise');
      const preLive = document.getElementById('am-pre-live');
      const scrollEl = document.getElementById('am-ed-scroll');

      [user, tools, typing, resp].forEach((el) => {
        if (!el) return;
        el.style.transition = 'none';
        el.style.opacity = '0';
        el.style.transform = 'translateY(10px)';
      });
      if (t2) t2.style.opacity = '0';
      if (t3) {
        t3.style.transition = 'none';
        t3.style.opacity = '0';
        t3.classList.remove('am-tool-done');
        const dot3 = t3.querySelector('.am-tool-dot');
        const chk3 = t3.querySelector('.am-tool-check');
        dot3?.classList.add('am-tool-pulse');
        dot3?.classList.remove('am-tool-ok');
        chk3?.classList.add('am-tool-check-hid');
      }
      if (status) {
        status.textContent = amT('idle');
        status.className = 'am-chat-status';
      }
      if (t1) {
        const dot = t1.querySelector('.am-tool-dot');
        dot?.classList.add('am-tool-pulse');
        dot?.classList.remove('am-tool-ok');
      }

      const show = (el, ms) => {
        if (!el) return;
        delay(() => {
          el.style.transition = `opacity 0.68s ${easeOut}, transform 0.68s ${easeOut}`;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, ms);
      };

      show(user, 520);
      delay(() => {
        if (status) {
          status.textContent = amT('running');
          status.className = 'am-chat-status am-chat-status-busy';
        }
      }, 920);
      show(tools, 1180);
      if (t2) {
        t2.style.opacity = '0';
        delay(() => {
          t2.style.transition = `opacity 0.62s ${easeSoft}`;
          t2.style.opacity = '1';
        }, 3180);
      }
      if (t3) {
        delay(() => {
          t3.style.transition = `opacity 0.55s ${easeSoft}`;
          t3.style.opacity = '1';
        }, 3520);
      }
      delay(() => {
        if (t1) {
          const dot = t1.querySelector('.am-tool-dot');
          dot?.classList.remove('am-tool-pulse');
          dot?.classList.add('am-tool-ok');
        }
      }, 3600);
      delay(() => {
        if (t3) {
          const dot = t3.querySelector('.am-tool-dot');
          const chk = t3.querySelector('.am-tool-check');
          dot?.classList.remove('am-tool-pulse');
          chk?.classList.remove('am-tool-check-hid');
          t3.classList.add('am-tool-done');
        }
        if (status) {
          status.textContent = amT('writing');
          status.className = 'am-chat-status am-chat-status-busy';
        }
      }, 4600);
      delay(() => {
        scrollWithin(scrollEl, preLive, 'center');
        preLive?.classList.add('am-pre--ai-focus');
      }, 4320);
      delay(() => {
        edRoot?.classList.add('am-ed--patched');
      }, 4880);
      scheduleTypewriter(patchInner, amT('patchCallout'), 4960, 19);
      delay(() => {
        kr4?.classList.remove('am-doc-kr4--hid');
      }, 5600);
      delay(() => {
        preLive?.classList.add('am-pre--caret-on');
        crowAi1?.classList.remove('am-crow--hid');
        crowAi1?.classList.add('am-crow--glow');
      }, 5900);
      delay(() => {
        crowAi1?.classList.remove('am-crow--glow');
        crowAi2?.classList.remove('am-crow--hid');
        crowAi2?.classList.add('am-crow--glow');
      }, 6500);
      delay(() => {
        crowAi2?.classList.remove('am-crow--glow');
        if (mapArg) {
          mapArg.textContent = 'filtered';
          mapArg.classList.add('am-code-ix');
        }
        crowPromise?.classList.add('am-crow--mut');
      }, 7100);
      delay(() => {
        mapArg?.classList.remove('am-code-ix');
        preLive?.classList.remove('am-pre--caret-on', 'am-pre--ai-focus');
      }, 8200);
      delay(() => {
        scrollWithin(scrollEl, kr4, 'nearest');
      }, 8600);
      delay(() => {
        if (status) {
          status.textContent = amT('generating');
          status.className = 'am-chat-status am-chat-status-gen';
        }
      }, 9000);
      show(typing, 9120);
      delay(() => {
        if (typing) {
          typing.style.transition = `opacity 0.52s ${easeSoft}`;
          typing.style.opacity = '0';
        }
      }, 11200);
      delay(() => {
        if (status) {
          status.textContent = amT('idle');
          status.className = 'am-chat-status';
        }
      }, 12000);
      show(resp, 10400);
    }

    function restartCssAnim(sel) {
      const el = root.querySelector(sel);
      if (!el) return;
      el.style.animation = 'none';
      void el.offsetWidth;
      el.style.animation = '';
    }

    function advance() {
      clearTimers();
      const prevPhase = root.getAttribute('data-phase');
      const phase = phases[idx];
      root.setAttribute('data-phase', phase);

      if (phase === 'graph') {
        restartCssAnim('.am-gnode-hub .am-glow');
        animateGraph();
      }
      if (phase === 'ai-chat') animateChat();
      if (phase === 'editor') {
        if (prevPhase === 'ai-chat') {
          smoothScrollEditorTop();
          delay(() => runEditorAnim(), reduceMotion ? 40 : 420);
        } else {
          runEditorAnim();
        }
      }

      let waitMs = durations[idx];
      if (phase === 'editor' && prevPhase === 'ai-chat' && !reduceMotion) {
        waitMs += 420;
      }

      delay(() => {
        idx = (idx + 1) % phases.length;
        advance();
      }, waitMs);
    }

    function estimateTypeMs(text, baseSpeed) {
      return text.length * (baseSpeed + 28) + 400;
    }

    delay(advance, 720);
  })();
</script>

