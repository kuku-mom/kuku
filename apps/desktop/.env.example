# Copy to `.env` and edit as needed. Vite picks these up at dev/build
# time and inlines them into the JS bundle — a rebuild is required
# after changes.

# Base URL for the kuku API server. Used by the AI chat plugin
# (`provider = remote`) and other call sites that need to reach
# server-side Connect RPC endpoints.
VITE_KUKU_API_URL=https://api.kuku.mom

# Base URL for the public web (account dashboard "Manage my account"
# link). Set to the port your local web stack serves on — the docker
# compose setup at infra/docker/local/ uses 8081; `astro dev` directly
# defaults to 4321.
VITE_KUKU_WEB_URL=http://localhost:8081
