# Dev server config for `go run ./cmd/server` against the `pnpm deps:up`
# stack (test/docker-compose.test.yml → postgres :5555, mailpit SMTP :1025,
# mailpit UI :8025). Copy to `.env` (gitignored) and edit as needed.

# ─── Server runtime ──────────────────────────────────────────────────
PORT=8080
ENV=development
LOG_LEVEL=info
LOG_FORMAT=pretty

# ─── Database ────────────────────────────────────────────────────────
# Migrations stay manual in dev so a mid-edit schema change doesn't
# silently apply on server reload.
DATABASE_URL=postgres://kuku:kuku@localhost:5555/kuku?sslmode=disable
AUTO_MIGRATION=false

# ─── Secrets ─────────────────────────────────────────────────────────
# This exact string is the magic dev fallback that config.Validate
# rejects in production. Any other non-empty value also works locally.
JWT_SECRET=change-me-in-development

# ─── OAuth (optional) ────────────────────────────────────────────────
# Register dev apps against the localhost callback URLs below and paste
# credentials here to exercise the OAuth flow; leave blank to skip.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/auth/callback/github

# ─── CORS + redirects ────────────────────────────────────────────────
# 4321 is the astro dev server; 3000 covers a Next-style alt frontend.
CLIENT_SUCCESS_URL=http://localhost:4321/auth/done?success=true
CLIENT_ERROR_URL=http://localhost:4321/auth/done
CLIENT_WEB_URL=http://localhost:4321
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000

# ─── Sessions ────────────────────────────────────────────────────────
SESSION_MAX_AGE=720h
SESSION_INACTIVITY=336h

# ─── Trusted proxies ─────────────────────────────────────────────────
# Empty locally — direct loopback hits only. Set a CSV of CIDRs / IPs
# when running behind an LB or reverse proxy; otherwise the real-IP
# middleware ignores X-Forwarded-For to prevent spoofing.
TRUSTED_PROXIES=

# ─── Email ───────────────────────────────────────────────────────────
# mailpit catches every outbound message. Read delivered OTPs at
# http://localhost:8025 during the email sign-in flow. Switch to `ses`
# only if you're deliberately testing the SES path locally (requires
# AWS_REGION + credentials from the SDK's default chain).
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=noreply@kuku.mom
EMAIL_FROM_NAME=kuku
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── AI (optional) ───────────────────────────────────────────────────
# Empty key → AI endpoints return ErrNotConfigured; auth / db flows are
# unaffected, so most dev tasks don't need to set this. The Gemini model is
# pinned in server code, not configured through env.
GEMINI_API_KEY=

# ─── E2EE Sync dogfood (local/dev path) ──────────────────────────────
# Phase3 starts with LocalObjectStore for development and protocol
# validation. Production transfer must use presigned object storage later;
# direct byte RPCs are rejected by config validation in production.
SYNC_FEATURE_ENABLED=true
SYNC_OBJECT_STORE_DRIVER=local
SYNC_LOCAL_OBJECT_DIR=.data/sync-objects
# S3-compatible dogfood/prod path. Use SYNC_OBJECT_STORE_DRIVER=s3 for AWS S3,
# or s3_compatible for R2/RustFS/MinIO-compatible endpoints. Credentials may
# come from the AWS SDK default chain; set the explicit keys only for local/dev.
SYNC_S3_ENDPOINT=
SYNC_S3_REGION=us-east-1
SYNC_S3_BUCKET=
SYNC_S3_ACCESS_KEY_ID=
SYNC_S3_SECRET_ACCESS_KEY=
SYNC_S3_FORCE_PATH_STYLE=false
SYNC_PRESIGN_TTL=10m
SYNC_DIRECT_BYTES_DEV_ENABLED=true
SYNC_MAX_WORKSPACES_PER_USER=5
SYNC_MAX_TOTAL_STORAGE_BYTES_PER_USER=1073741824
SYNC_MAX_STORAGE_BYTES_PER_WORKSPACE=536870912
SYNC_MAX_SINGLE_BLOB_BYTES=33554432
SYNC_MAX_PENDING_UPLOAD_BYTES_PER_WORKSPACE=134217728
SYNC_MAX_PENDING_UPLOAD_AGE=24h
