# Copy to `env` and run docker compose with `--env-file env`.
#
# For same-machine testing, defaults work. For testing from another
# computer on the same LAN, set both PUBLIC_HOST and RUSTFS_ENDPOINT_HOST
# to the server Mac's LAN IP, for example:
#
#   PUBLIC_HOST=192.168.0.42
#   RUSTFS_ENDPOINT_HOST=192.168.0.42

# ─── Host/port exposure ──────────────────────────────────────────────
HOST_BIND=0.0.0.0
PUBLIC_HOST=localhost
SERVER_PORT=8080
WEB_PORT=8081
POSTGRES_PORT=5555
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# RustFS endpoint host baked into server presigned URLs.
# Same-machine default: host.docker.internal is reachable from the server
# container and from macOS. LAN testing: change to the server Mac's LAN IP.
RUSTFS_ENDPOINT_HOST=host.docker.internal

# Optional override. Leave empty unless testing a custom browser origin.
# ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# ─── Server runtime ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
JWT_SECRET=change-me-in-development

# ─── Postgres container ──────────────────────────────────────────────
POSTGRES_DB=kuku
POSTGRES_USER=kuku
POSTGRES_PASSWORD=dev

# ─── Mailpit / email ─────────────────────────────────────────────────
EMAIL_FROM_ADDRESS=noreply@kuku.local
EMAIL_FROM_NAME=Kuku Local Test

# ─── RustFS / S3-compatible sync storage ─────────────────────────────
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
SYNC_S3_BUCKET=kuku-sync-test
SYNC_S3_REGION=us-east-1
SYNC_PRESIGN_TTL=10m

# ─── Sync quotas ─────────────────────────────────────────────────────
SYNC_MAX_WORKSPACES_PER_USER=5
SYNC_MAX_TOTAL_STORAGE_BYTES_PER_USER=1073741824
SYNC_MAX_STORAGE_BYTES_PER_WORKSPACE=536870912
SYNC_MAX_SINGLE_BLOB_BYTES=33554432
SYNC_MAX_PENDING_UPLOAD_BYTES_PER_WORKSPACE=134217728
SYNC_MAX_PENDING_UPLOAD_AGE=24h

# ─── Optional providers ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Gemini model is pinned in server code, not configured through env.
GEMINI_API_KEY=
TRUSTED_PROXIES=
