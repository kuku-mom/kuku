# Copy to `env` (gitignored) and edit in place. Preview stack targets
# the `preview-api.kuku.mom` hostname fronted by Cloudflare Tunnel;
# values below assume that topology.

# ─── Cloudflare Tunnel ───────────────────────────────────────────────
# Generate at CF dashboard: Zero Trust → Networks → Tunnels → Create.
# Pick the "Docker" connector — CF shows a `docker run` command with
# `--token <TOKEN>`; copy that token here. Then in the same dashboard
# add a Public Hostname for the tunnel:
#   Subdomain: preview-api   Domain: kuku.mom
#   Service:   http://server:8080  (service=docker service name)
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Postgres container ──────────────────────────────────────────────
POSTGRES_DB=kuku_preview
POSTGRES_USER=kuku
POSTGRES_PASSWORD=

# ─── Server runtime ──────────────────────────────────────────────────
# `production` flips config.Validate into strict mode (refuses default
# JWT secret, refuses `ALLOWED_ORIGINS=*`, warns if TRUSTED_PROXIES is
# unset).
ENV=production
PORT=8080
LOG_LEVEL=info
LOG_FORMAT=json

# postgres hostname resolves via compose network.
DATABASE_URL=postgres://kuku:${POSTGRES_PASSWORD}@postgres:5432/kuku_preview?sslmode=disable
AUTO_MIGRATION=true

# MUST differ from prod so sessions can't cross-contaminate.
# Generate: `openssl rand -base64 48`
JWT_SECRET=

# ─── OAuth (preview-specific apps) ───────────────────────────────────
# Register separate OAuth apps for preview — do not reuse prod client
# credentials. Redirect URLs must exactly match what's set here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://preview-api.kuku.mom/auth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://preview-api.kuku.mom/auth/callback/github

# ─── CORS + redirects ────────────────────────────────────────────────
# ALLOWED_ORIGINS must include every origin that calls this API from a
# browser (preview Pages, a CF Pages branch preview URL, etc). The
# desktop app talks via native HTTP so it isn't subject to CORS.
ALLOWED_ORIGINS=https://preview.kuku.mom
CLIENT_SUCCESS_URL=https://preview.kuku.mom/auth/done?success=true
CLIENT_ERROR_URL=https://preview.kuku.mom/auth/done
CLIENT_WEB_URL=https://preview.kuku.mom

# ─── Sessions ────────────────────────────────────────────────────────
SESSION_MAX_AGE=720h
SESSION_INACTIVITY=336h

# ─── Trusted proxies ─────────────────────────────────────────────────
# With Cloudflare Tunnel the server sees cloudflared's sidecar IP as the
# immediate TCP peer — NOT a CF edge IP. So the trusted list must include
# the compose network's subnet (pinned to 172.28.0.0/16 in
# docker-compose.yml) so the real-IP middleware trusts cloudflared and
# reads `CF-Connecting-IP` instead of stamping every request with the
# bridge IP.
#
# The CF public ranges are kept in the list in case a future topology
# swaps Tunnel for a direct-exposure setup (e.g. CF proxy in front of a
# public host), where the peer would then be a CF edge IP.
# Keep in sync with https://www.cloudflare.com/ips/
TRUSTED_PROXIES=172.28.0.0/16,173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# ─── Email ───────────────────────────────────────────────────────────
# Preview mirrors prod's SES path on purpose: this stack is the dry-run
# that catches SES misconfig (sandbox, identity verification, IAM role
# scope) before the same change hits prod. Verify a preview-specific
# identity (domain `preview.kuku.mom` or the exact from-address below)
# in the SES console for AWS_REGION.
#
# To bounce emails into the built-in mailpit instead (e.g. when you're
# iterating on OTP content and don't want real delivery), flip
# EMAIL_PROVIDER to `smtp` and uncomment the SMTP block further down.
EMAIL_PROVIDER=ses
EMAIL_FROM_ADDRESS=noreply@preview.kuku.mom
EMAIL_FROM_NAME=Kuku Preview

# Match the region your SES identities are verified in. Keep this in
# sync with prod unless you intentionally split regions.
AWS_REGION=us-east-1

# Preferred: IAM role on the host / task. Only set these when the host
# has no instance role (plain VPS). The AWS SDK picks them up
# automatically when present.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Fallback: bounce into the mailpit sidecar that ships with the preview
# compose stack. Uncomment + flip EMAIL_PROVIDER=smtp to use.
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ─── AI ──────────────────────────────────────────────────────────────
# Preview + prod can share a key; traffic is the user's activity either
# way. Use separate billing projects at Google if you want clean
# cost attribution. Gemini model is pinned in server code, not configured
# through env.
GEMINI_API_KEY=
