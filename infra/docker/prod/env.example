# Copy to `env` (gitignored) and edit in place. Prod stack targets the
# `api.kuku.mom` hostname fronted by Cloudflare Tunnel; values below
# assume that topology.

# ─── Cloudflare Tunnel ───────────────────────────────────────────────
# Generate at CF dashboard: Zero Trust → Networks → Tunnels → Create.
# Pick the "Docker" connector — CF shows a `docker run` command with
# `--token <TOKEN>`; copy that token here. Then in the same dashboard
# add a Public Hostname for the tunnel:
#   Subdomain: api          Domain: kuku.mom
#   Service:   http://server:8080  (service=docker service name)
#
# This must be a NEW tunnel — don't reuse the preview tunnel token.
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Server runtime ──────────────────────────────────────────────────
# `production` flips config.Validate into strict mode (refuses default
# JWT secret, refuses `ALLOWED_ORIGINS=*`, warns if TRUSTED_PROXIES is
# unset).
ENV=production
PORT=8080
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Database ────────────────────────────────────────────────────────
# External managed Postgres (RDS / Neon / Cloud SQL / Supabase). The
# compose stack no longer runs its own postgres container in prod —
# upgrades, backups, and replica setup live with the managed provider
# instead of next to the API. Require TLS in prod (sslmode=require).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/kuku?sslmode=require
# Keep true for first boot so migrations run automatically. Once the
# schema is stable and you want migrations gated behind a manual step,
# flip to false and run `go run ./cmd/server migrate` out of band.
AUTO_MIGRATION=true

# MUST differ from preview so sessions can't cross-contaminate.
# Generate: `openssl rand -base64 48`
JWT_SECRET=

# ─── OAuth (prod-specific apps) ──────────────────────────────────────
# Register separate OAuth apps for prod — do not reuse preview client
# credentials. Redirect URLs must exactly match what's set here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://api.kuku.mom/auth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://api.kuku.mom/auth/callback/github

# ─── CORS + redirects ────────────────────────────────────────────────
# ALLOWED_ORIGINS must include every origin that calls this API from a
# browser. The desktop app talks via native HTTP so it isn't subject to
# CORS. Include both apex and www so whichever canonical URL the web
# bundle is served at keeps working.
ALLOWED_ORIGINS=https://kuku.mom,https://www.kuku.mom
CLIENT_SUCCESS_URL=https://kuku.mom/auth/done?success=true
CLIENT_ERROR_URL=https://kuku.mom/auth/done
CLIENT_WEB_URL=https://kuku.mom

# ─── Sessions ────────────────────────────────────────────────────────
SESSION_MAX_AGE=720h
SESSION_INACTIVITY=336h

# ─── Trusted proxies ─────────────────────────────────────────────────
# With Cloudflare Tunnel the server sees cloudflared's sidecar IP as the
# immediate TCP peer — NOT a CF edge IP. So the trusted list must include
# the compose network's subnet (pinned to 172.29.0.0/16 in
# docker-compose.yml) so the real-IP middleware trusts cloudflared and
# reads `CF-Connecting-IP` instead of stamping every request with the
# bridge IP.
#
# The CF public ranges are kept in the list in case a future topology
# swaps Tunnel for a direct-exposure setup (e.g. CF proxy in front of a
# public host), where the peer would then be a CF edge IP.
# Keep in sync with https://www.cloudflare.com/ips/
TRUSTED_PROXIES=172.29.0.0/16,173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# ─── Email ───────────────────────────────────────────────────────────
# Prod uses Amazon SES (v2 SendEmail). The sender's domain (or the exact
# from-address) must be verified in the SES console for the AWS_REGION
# below. While the account is still in SES sandbox, recipients must also
# be verified — request production access before launch.
EMAIL_PROVIDER=ses
EMAIL_FROM_ADDRESS=noreply@kuku.mom
EMAIL_FROM_NAME=Kuku

# SES region. Domain verification is regional — pick the same region your
# SES identities live in. Common: us-east-1, us-west-2, eu-west-1.
AWS_REGION=us-east-1

# AWS credentials resolve through the SDK's default provider chain.
# Preferred in prod: attach an IAM role to the VM / ECS task / EKS pod
# with the `ses:SendEmail` permission scoped to the verified identity —
# no secrets on disk. Only fall back to static keys when the host has no
# instance role (e.g. a plain VPS). If you set them here they are
# consumed by the AWS SDK automatically; leave blank otherwise.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# SMTP is the fallback provider (mailpit in local, Resend/Mailgun if you
# swap off SES). Leave the block commented while EMAIL_PROVIDER=ses so
# nothing ambiguous sneaks into prod config.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ─── AI ──────────────────────────────────────────────────────────────
# Use a dedicated prod API key + billing project so cost attribution
# stays clean and a preview-side quota blow-up can't starve prod. Gemini
# model is pinned in server code, not configured through env.
GEMINI_API_KEY=
