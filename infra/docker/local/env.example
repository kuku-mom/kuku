# Copy to `env` (gitignored) and edit in place. Values below are dev
# defaults safe to keep as-is unless noted.

# ─── Web build-time (baked into JS bundle) ───────────────────────────
# Overrides docker-compose's build.args default. Keep aligned with
# SERVER_PORT below; web must know exactly where to reach the API.
PUBLIC_KUKU_API_BASE_URL=http://localhost:8080

# ─── Server runtime ──────────────────────────────────────────────────
ENV=development
PORT=8080
LOG_LEVEL=debug
LOG_FORMAT=pretty

# postgres hostname resolves via compose network.
DATABASE_URL=postgres://kuku:dev@postgres:5432/kuku?sslmode=disable
AUTO_MIGRATION=true

# Dev default — config.Validate rejects this when ENV=production so
# it's safe to check in. Any non-empty value that isn't the magic
# "change-me-in-development" string works locally.
JWT_SECRET=change-me-in-development

# ─── OAuth (optional for auth smoke testing) ─────────────────────────
# Register a local-only Google/GitHub app with the redirect URLs below
# and paste the client id/secret here to exercise the callback flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/auth/callback/github

# ─── CORS + redirects ────────────────────────────────────────────────
# ALLOWED_ORIGINS must list the web host port — CORS middleware rejects
# anything else. Comma-separated.
ALLOWED_ORIGINS=http://localhost:8081
CLIENT_SUCCESS_URL=http://localhost:8081/auth/done?success=true
CLIENT_ERROR_URL=http://localhost:8081/auth/done
CLIENT_WEB_URL=http://localhost:8081

# ─── Sessions ────────────────────────────────────────────────────────
SESSION_MAX_AGE=720h
SESSION_INACTIVITY=336h

# ─── Email ───────────────────────────────────────────────────────────
# mailpit container catches every outbound email. Open
# http://localhost:8025 to read OTP codes during the email sign-in
# flow. SMTP_HOST uses the compose service name so the server
# resolves it over the internal network; no auth needed locally.
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=noreply@kuku.local
EMAIL_FROM_NAME=Kuku Dev
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── AI (optional; empty → server returns ErrNotConfigured) ──────────
# Gemini model is pinned in server code, not configured through env.
GEMINI_API_KEY=

# ─── E2EE Sync dogfood (local/dev path) ──────────────────────────────
SYNC_FEATURE_ENABLED=true
SYNC_OBJECT_STORE_DRIVER=local
SYNC_LOCAL_OBJECT_DIR=/data/sync-objects
SYNC_DIRECT_BYTES_DEV_ENABLED=true
SYNC_MAX_WORKSPACES_PER_USER=5
SYNC_MAX_TOTAL_STORAGE_BYTES_PER_USER=1073741824
SYNC_MAX_STORAGE_BYTES_PER_WORKSPACE=536870912
SYNC_MAX_SINGLE_BLOB_BYTES=33554432
SYNC_MAX_PENDING_UPLOAD_BYTES_PER_WORKSPACE=134217728
SYNC_MAX_PENDING_UPLOAD_AGE=24h

# ─── Trusted proxies ─────────────────────────────────────────────────
# Empty locally — no proxy in front of the server, so X-Forwarded-For
# should be ignored to prevent spoofing.
TRUSTED_PROXIES=

# ─── Postgres container (docker-compose uses this) ───────────────────
POSTGRES_DB=kuku
POSTGRES_USER=kuku
POSTGRES_PASSWORD=dev
